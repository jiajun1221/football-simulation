<UserControl x:Class="FootballSimulation.Wpf.Controls.FormationSetupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls"
             MinHeight="560">
    <UserControl.Resources>
        <Style x:Key="PitchPlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormationCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="PresetButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F6" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D5DEE8" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="#7A8798" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
        </Style>

        <Style x:Key="PresetSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonStyle}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        </Style>

        <Style x:Key="PresetDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonStyle}">
            <Setter Property="Background" Value="#FEE2E2" />
            <Setter Property="Foreground" Value="#991B1B" />
            <Setter Property="BorderBrush" Value="#FCA5A5" />
        </Style>

        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="1,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PitchPlayerCardTemplate">
            <Border Width="116"
                    MinHeight="66"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding MutedForeground}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="0,0,4,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OverallText}"
                                   Foreground="{Binding OverallForeground}"
                                   FontSize="9"
                                   FontWeight="Black" />
                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:FlagBadge FlagSource="{Binding FlagImagePath}"
                                            ToolTip="{Binding NationalityName}"
                                            Width="20"
                                            Height="14"
                                            Margin="0,0,4,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PlayerName}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding FormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding FormBadgeText}"
                                       Foreground="{Binding FormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubstituteCardTemplate">
            <Border MinWidth="168"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="SubstituteCard_PreviewMouseLeftButtonDown"
                    MouseMove="SubstituteCard_MouseMove"
                    PreviewDrop="SubstituteCard_Drop"
                    PreviewDragOver="SubstituteCard_DragOver">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding TextForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:FlagBadge FlagSource="{Binding FlagImagePath}"
                                            ToolTip="{Binding NationalityName}"
                                            Width="20"
                                            Height="14"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding BenchFormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding BenchFormBadgeText}"
                                       Foreground="{Binding BenchFormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UnavailablePlayerCardTemplate">
            <Border MinWidth="168"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    Opacity="0.82"
                    Cursor="No"
                    ToolTip="{Binding Tooltip}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OverallText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.5"
                                   FontWeight="Black"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:FlagBadge FlagSource="{Binding FlagImagePath}"
                                            ToolTip="{Binding NationalityName}"
                                            Width="20"
                                            Height="14"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <WrapPanel Grid.Row="2" Margin="0,3,0,0">
                        <Border Background="{Binding StatusBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                Margin="0,0,2,2">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding BenchFormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                Margin="0,0,2,2">
                            <TextBlock Text="{Binding BenchFormBadgeText}"
                                       Foreground="{Binding BenchFormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                      Margin="0,0,0,2">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </WrapPanel>

                    <TextBlock Grid.Row="3"
                               Text="{Binding UnavailableInfoText}"
                               Foreground="#FECACA"
                               FontSize="8"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0" />
                    <ProgressBar Grid.Row="4"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#16894A"
                        BorderBrush="#B8F2CD"
                        BorderThickness="2"
                        CornerRadius="18">
                    <Grid ClipToBounds="True">
                        <Viewbox Stretch="Fill"
                                 IsHitTestVisible="False"
                                 Margin="16">
                            <Canvas Width="1000" Height="680">
                                <Rectangle Width="1000"
                                           Height="680"
                                           Stroke="#B8F2CD"
                                           StrokeThickness="5"
                                           Opacity="0.72" />
                                <Line X1="0" Y1="0" X2="1000" Y2="0" Stroke="#B8F2CD" StrokeThickness="5" Opacity="0.72" />
                                <Ellipse Width="230" Height="230" Canvas.Left="385" Canvas.Top="-115" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.58" />
                                <Ellipse Width="10" Height="10" Canvas.Left="495" Canvas.Top="-5" Fill="#B8F2CD" Opacity="0.78" />

                                <Rectangle Width="500" Height="156" Canvas.Left="250" Canvas.Top="524" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.66" />
                                <Rectangle Width="250" Height="70" Canvas.Left="375" Canvas.Top="610" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.66" />
                                <Ellipse Width="10" Height="10" Canvas.Left="495" Canvas.Top="557" Fill="#B8F2CD" Opacity="0.72" />
                                <Path Data="M 414 524 A 96 96 0 0 1 586 524" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.55" Fill="Transparent" />
                            </Canvas>
                        </Viewbox>

                        <Canvas x:Name="PitchCanvas"
                                Margin="16"
                                Background="Transparent"
                                AllowDrop="True"
                                SizeChanged="PitchCanvas_SizeChanged"
                                MouseLeftButtonDown="PitchCanvas_MouseLeftButtonDown" />

                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,18,18"
                                Padding="10,8"
                                CornerRadius="13"
                                Background="{DynamicResource TacticalFloatingPanelBackground}"
                                BorderBrush="{DynamicResource TacticalFloatingPanelBorder}"
                                BorderThickness="1.2">
                            <Border.Effect>
                                <DropShadowEffect Color="#071226"
                                                  BlurRadius="16"
                                                  ShadowDepth="2"
                                                  Opacity="0.26" />
                            </Border.Effect>
                            <StackPanel Width="168">
                                <TextBlock Text="Formation"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="FormationComboBox"
                                          Height="28"
                                          FontSize="12"
                                          SelectionChanged="FormationComboBox_SelectionChanged">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="10"
                                                               FontWeight="Black"
                                                               Foreground="#2563EB"
                                                               Margin="6,6,0,3" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ComboBox.GroupStyle>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="#0F6D39"
                        BorderBrush="#B8F2CD"
                        BorderThickness="1.5"
                        CornerRadius="18"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Substitutes"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="FilterTextBlock"
                                       Grid.Column="1"
                                       Text="All players"
                                       Foreground="#DDF7E8"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button x:Name="ClearFilterButton"
                                    Grid.Column="2"
                                    Content="x"
                                    Width="22"
                                    Height="22"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    FontSize="11"
                                    FontWeight="Black"
                                    ToolTip="Show all substitutes"
                                    Visibility="Collapsed"
                                    Click="ClearFilterButton_Click" />
                        </Grid>
                        <ListBox x:Name="SubstituteListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemTemplate="{StaticResource SubstituteCardTemplate}"
                                 AllowDrop="True"
                                 PreviewDragOver="SubstituteListBox_DragOver"
                                 PreviewDrop="SubstituteListBox_Drop"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Opacity" Value="0.94" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <TextBlock x:Name="UnavailableTitleTextBlock"
                                   Grid.Row="2"
                                   Text="Unavailable Players"
                                   Foreground="#FFD1D1"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,12,0,6"
                                   Visibility="Collapsed" />
                        <ListBox x:Name="UnavailableListBox"
                                 Grid.Row="3"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemTemplate="{StaticResource UnavailablePlayerCardTemplate}"
                                 Visibility="Collapsed"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource AppCardBackground}"
                CornerRadius="18"
                Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Tactic"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,0,0,6" />
                    <controls:TacticalSettingsPanel x:Name="TacticalSettingsPanel"
                                                    PanelMaxHeight="350"
                                                    IsCompact="False"
                                                    TacticsChanged="TacticalSettingsPanel_TacticsChanged" />

                    <Border Background="{DynamicResource AppSecondaryCardBackground}"
                            BorderBrush="{DynamicResource AppCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Saved Setups"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,0,0,3" />
                            <TextBlock Text="Stores formation, XI, bench, and tactics."
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <Grid>
                                <ComboBox x:Name="PresetComboBox"
                                          Height="30"
                                          DisplayMemberPath="Name"
                                          TextSearch.TextPath="Name"
                                          SelectionChanged="PresetComboBox_SelectionChanged"
                                          ToolTip="Saved lineup, formation, bench, and tactic setup" />
                                <TextBlock Text="No saved setups yet"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasItems, ElementName=PresetComboBox}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <TextBox x:Name="PresetNameTextBox"
                                     Height="30"
                                     Padding="8,4"
                                     Margin="0,8,0,8"
                                     Text="Default"
                                     TextChanged="PresetNameTextBox_TextChanged"
                                     ToolTip="Suggested setup slots: Default, Attacking, Defensive, Counter Attack, Custom" />
                            <Button x:Name="SavePresetButton"
                                    Content="Save Current Setup"
                                    Style="{StaticResource PresetPrimaryButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,8"
                                    Click="SavePresetButton_Click" />
                            <UniformGrid Columns="3"
                                         Margin="0,0,0,8">
                                <Button x:Name="OverwritePresetButton"
                                        Content="Overwrite"
                                        Style="{StaticResource PresetSecondaryButtonStyle}"
                                        Margin="0,0,4,0"
                                        Click="OverwritePresetButton_Click" />
                                <Button x:Name="RenamePresetButton"
                                        Content="Rename"
                                        Style="{StaticResource PresetSecondaryButtonStyle}"
                                        Margin="2,0,2,0"
                                        Click="RenamePresetButton_Click" />
                                <Button x:Name="DeletePresetButton"
                                        Content="Delete"
                                        Style="{StaticResource PresetDangerButtonStyle}"
                                        Margin="4,0,0,0"
                                        Click="DeletePresetButton_Click" />
                            </UniformGrid>
                            <TextBlock x:Name="PresetSlotUsageTextBlock"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
