<Window x:Class="FootballSimulation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Premier League Simulator"
        Height="780"
        Width="1280"
        MinHeight="700"
        MinWidth="1040"
        Icon="Assets/App/FootballSimulator_AppIcon.ico"
        Background="{DynamicResource AppPageBackground}">
    <Grid Background="{DynamicResource AppPageBackground}">
        <ContentControl x:Name="MainContent" />
        <Button x:Name="ThemeToggleButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,12,0"
                Width="34"
                Height="30"
                Padding="0"
                Cursor="Hand"
                Panel.ZIndex="20"
                Click="ThemeToggleButton_Click"
                Background="{DynamicResource AppToggleBackground}"
                Foreground="{DynamicResource AppToggleForeground}"
                BorderBrush="{DynamicResource AppToggleBorderBrush}"
                BorderThickness="1"
                FontFamily="Segoe UI Emoji"
                FontSize="14"
                FontWeight="SemiBold">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ToggleBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="15">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            <Setter TargetName="ToggleBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="12"
                                                      ShadowDepth="0"
                                                      Color="#38BDF8"
                                                      Opacity="0.45" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>
