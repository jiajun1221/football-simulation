<Window x:Class="FootballSimulation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Premier League Simulator"
        Height="780"
        Width="1280"
        MinHeight="700"
        MinWidth="1040"
        Background="#E9EEF4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#101C2F"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Premier League Simulator"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold" />
                <TextBlock Text="Team selection, dashboard, pre-match, live match, halftime, and result screens."
                           Foreground="#BFD0E5"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ContentControl x:Name="MainContent"
                        Grid.Row="1" />
    </Grid>
</Window>
