<Window x:Class="FootballSimulation.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Football Simulator - By ScorpJJ"
        Height="780"
        Width="1280"
        MinHeight="700"
        MinWidth="1040"
        Icon="Assets/App/FootballSimulator_AppIcon.ico"
        Background="{DynamicResource AppPageBackground}">
    <Grid Background="{DynamicResource AppPageBackground}">
        <ContentControl x:Name="MainContent" />
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Margin="0,8,12,0"
                    Panel.ZIndex="20">
            <Button x:Name="ShellSaveButton"
                    Width="34"
                    Height="30"
                    Padding="0"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Click="ShellSaveButton_Click"
                    Background="#2563EB"
                    Foreground="#FFFFFF"
                    BorderBrush="#2563EB"
                    BorderThickness="1"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    FontWeight="SemiBold"
                    ToolTip="Save game"
                    Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SaveBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SaveBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="SaveBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Content>&#xE74E;</Button.Content>
            </Button>

            <Button x:Name="ShellStatsButton"
                    Width="34"
                    Height="30"
                    Padding="0"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Click="ShellStatsButton_Click"
                    Background="#0EA5E9"
                    Foreground="#FFFFFF"
                    BorderBrush="#0EA5E9"
                    BorderThickness="1"
                    FontFamily="Segoe UI Emoji"
                    FontSize="14"
                    FontWeight="SemiBold"
                    ToolTip="League Player Stats"
                    Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="StatsBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StatsBorder" Property="Background" Value="#0284C7" />
                                <Setter TargetName="StatsBorder" Property="BorderBrush" Value="#0284C7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Content>📊</Button.Content>
            </Button>

            <Button x:Name="ThemeToggleButton"
                    Width="34"
                    Height="30"
                    Padding="0"
                    Cursor="Hand"
                    Click="ThemeToggleButton_Click"
                    Background="{DynamicResource AppToggleBackground}"
                    Foreground="{DynamicResource AppToggleForeground}"
                    BorderBrush="{DynamicResource AppToggleBorderBrush}"
                    BorderThickness="1"
                    FontFamily="Segoe UI Emoji"
                    FontSize="14"
                    FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                <Setter TargetName="ToggleBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12"
                                                          ShadowDepth="0"
                                                          Color="#38BDF8"
                                                          Opacity="0.45" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
