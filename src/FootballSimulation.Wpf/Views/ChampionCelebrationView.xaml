<UserControl x:Class="FootballSimulation.Wpf.Views.ChampionCelebrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#07110B">
    <Grid x:Name="RootGrid">
        <Grid.Background>
            <ImageBrush x:Name="BackgroundImageBrush"
                        ImageSource="pack://application:,,,/Assets/Backgrounds/main-menu-stadium.png"
                        Stretch="UniformToFill" />
        </Grid.Background>

        <Rectangle x:Name="OverlayRectangle" Fill="#B0071110" />
        <Rectangle>
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.5,0.42" GradientOrigin="0.5,0.42" RadiusX="0.74" RadiusY="0.74">
                    <GradientStop x:Name="AccentGradientStop" Color="#66FACC15" Offset="0" />
                    <GradientStop Color="#22071110" Offset="0.46" />
                    <GradientStop Color="#DD071110" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Canvas IsHitTestVisible="False">
            <TextBlock Text="✦" Foreground="#FDE68A" FontSize="28" Canvas.Left="90" Canvas.Top="70" Opacity="0.85" />
            <TextBlock Text="✦" Foreground="#FBBF24" FontSize="18" Canvas.Right="130" Canvas.Top="92" Opacity="0.75" />
            <TextBlock Text="✦" Foreground="#FEF3C7" FontSize="22" Canvas.Left="190" Canvas.Bottom="110" Opacity="0.70" />
            <TextBlock Text="✦" Foreground="#F59E0B" FontSize="24" Canvas.Right="220" Canvas.Bottom="150" Opacity="0.65" />
        </Canvas>

        <Viewbox Margin="18"
                 Stretch="Uniform"
                 StretchDirection="DownOnly">
        <Border x:Name="CelebrationCardBorder"
                Width="720"
                Padding="22"
                CornerRadius="24"
                Background="#CC071A12"
                BorderBrush="#D6B15E"
                BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="28"
                                  ShadowDepth="8"
                                  Opacity="0.36" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                    <Border Width="66"
                            Height="66"
                            CornerRadius="33"
                            Background="#F8FAFC"
                            BorderBrush="#FACC15"
                            BorderThickness="2.5"
                            Padding="8"
                            HorizontalAlignment="Center">
                        <Image x:Name="ClubLogoImage"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock x:Name="CelebrationTitleTextBlock"
                               Text="Trophy Celebration"
                               Foreground="#FDE68A"
                               FontSize="28"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,12,0,0" />
                    <TextBlock x:Name="ClubNameTextBlock"
                               Foreground="#FFFFFF"
                               FontSize="38"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="SeasonTextBlock"
                               Foreground="#FCD34D"
                               FontSize="14"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               Margin="0,3,0,0" />
                </StackPanel>

                <Image x:Name="TrophyImage"
                       Grid.Row="1"
                       Width="190"
                       Height="220"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,8" />

                <TextBlock x:Name="CelebrationTextBlock"
                           Grid.Row="2"
                           Foreground="#FFF7ED"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <Border Grid.Row="3"
                        x:Name="InfoBorder"
                        Background="#33FACC15"
                        BorderBrush="#D6B15E"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10"
                        Margin="0,0,0,14">
                    <TextBlock x:Name="CelebrationSubtitleTextBlock"
                               Text="The final whistle confirms a title-winning campaign. Enjoy the lap of honour before reviewing the full season."
                               Foreground="#FEF3C7"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Button x:Name="NextButton"
                        Grid.Row="4"
                        Content="Next"
                        Width="180"
                        Height="42"
                        HorizontalAlignment="Center"
                        Background="#FACC15"
                        Foreground="#111827"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        FontSize="16"
                        FontWeight="Black"
                        Click="NextButton_Click" />
            </Grid>
        </Border>
        </Viewbox>
    </Grid>
</UserControl>
