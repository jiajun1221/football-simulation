<UserControl x:Class="FootballSimulation.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.12"
                                      Color="#233A55" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDashboardButton" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Background" Value="{DynamicResource AppButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppButtonForeground}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppButtonForeground}" />
                            </Style>
                            <Style TargetType="AccessText">
                                <Setter Property="Foreground" Value="{DynamicResource AppButtonForeground}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="16,0"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Direction="270"
                                                  Opacity="0.20"
                                                  Color="#102033" />
                            </Border.Effect>
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AppButtonForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource TableHeaderBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TableHeaderForeground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LeagueTableRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppPanelBackground}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelectedTeam}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableCurrentClubBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource TableCurrentClubForeground}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LastFiveBadgeTemplate">
            <Border Width="20"
                    Height="20"
                    CornerRadius="10"
                    Background="{Binding BadgeBrush}"
                    Margin="2,0">
                <TextBlock Text="{Binding ResultType}"
                           Foreground="White"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FixtureCardTemplate">
            <Border Background="{DynamicResource AppSecondaryCardBackground}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="7"
                    Margin="0,0,6,0"
                    MinHeight="108"
                    VerticalAlignment="Stretch">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="1"
                                      Direction="270"
                                      Opacity="0.10"
                                      Color="#233A55" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{Binding HomeAwayBrush}"
                                CornerRadius="8"
                                Padding="5,2"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding HomeAwayText}"
                                       Foreground="{Binding HomeAwayForeground}"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding RoundText}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,5,0,4"
                          HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Image Source="{Binding OpponentLogoPath}"
                               Width="28"
                               Height="28"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />
                        <TextBlock Grid.Row="1"
                                   Text="{Binding OpponentName}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   LineHeight="11"
                                   HorizontalAlignment="Stretch" />
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding VenueText}"
                               FontSize="8"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               LineHeight="10"
                               HorizontalAlignment="Stretch" />
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="FixtureCardItemStyle" TargetType="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="24"
          Background="{DynamicResource AppPageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="62" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="54"
                            Height="54"
                            CornerRadius="16"
                            Background="{DynamicResource AppPanelBackground}"
                            HorizontalAlignment="Left">
                        <Image x:Name="SelectedClubLogoImage"
                               Width="42"
                               Height="42"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Club Dashboard"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}" />
                        <TextBlock x:Name="SelectedTeamTextBlock"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="Season 2025/26"
                                       FontSize="12"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,10,0" />
                            <ItemsControl x:Name="ClubFormItemsControl"
                                          ItemTemplate="{StaticResource LastFiveBadgeTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="1"
                             Columns="3"
                             Margin="0,0,0,18">
                    <Border Background="{DynamicResource AppSecondaryCardBackground}" CornerRadius="12" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Position" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" FontWeight="SemiBold" />
                            <TextBlock x:Name="PositionStatTextBlock" FontSize="18" Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSecondaryCardBackground}" CornerRadius="12" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Points" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" FontWeight="SemiBold" />
                            <TextBlock x:Name="PointsStatTextBlock" FontSize="18" Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSecondaryCardBackground}" CornerRadius="12" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Goal Diff" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" FontWeight="SemiBold" />
                            <TextBlock x:Name="GoalDifferenceStatTextBlock" FontSize="18" Foreground="{DynamicResource AppTextBrush}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Grid.Row="2" Margin="0,0,0,24">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Upcoming Match"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                x:Name="HomeAwayBadge"
                                CornerRadius="11"
                                Padding="11,5">
                            <TextBlock x:Name="HomeAwayBadgeTextBlock"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <Border Background="{DynamicResource AppSecondaryCardBackground}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="UpcomingRoundTextBlock"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel HorizontalAlignment="Center">
                                    <Image x:Name="UpcomingHomeLogoImage" Width="44" Height="44" Stretch="Uniform" />
                                    <TextBlock x:Name="UpcomingHomeNameTextBlock"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="vs"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Image x:Name="UpcomingAwayLogoImage" Width="44" Height="44" Stretch="Uniform" />
                                    <TextBlock x:Name="UpcomingAwayNameTextBlock"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="VenueTextBlock"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="PrepareMatchButton"
                            Style="{StaticResource PrimaryDashboardButton}"
                            Content="Prepare Match"
                            Click="PrepareMatchButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Upcoming Club Fixtures"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,0,0,8" />
                    <ItemsControl x:Name="UpcomingFixturesItemsControl"
                                  ItemTemplate="{StaticResource FixtureCardTemplate}"
                                  ItemContainerStyle="{StaticResource FixtureCardItemStyle}"
                                  VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="League Table"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Last 5:"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <Border Width="18" Height="18" CornerRadius="9" Background="#2FA84F" Margin="0,0,4,0">
                            <TextBlock Text="W" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#9AA3AF" Margin="0,0,4,0">
                            <TextBlock Text="D" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#D94343">
                            <TextBlock Text="L" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Champions League" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#F97316" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Europa League" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Conference qualifiers" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" Background="#EF4444" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Relegation" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <DataGrid x:Name="LeagueTableDataGrid"
                          Grid.Row="2"
                          Style="{StaticResource ModernDataGrid}"
                          RowStyle="{StaticResource LeagueTableRowStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="9">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ZoneBrush}"
                                            Width="5"
                                            HorizontalAlignment="Left"
                                            Margin="0,5" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="38" />
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding LogoPath}"
                                           Width="26"
                                           Height="26"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Club" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Club}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="MP" Binding="{Binding Played}" Width="44" />
                        <DataGridTextColumn Header="W" Binding="{Binding Wins}" Width="40" />
                        <DataGridTextColumn Header="D" Binding="{Binding Draws}" Width="40" />
                        <DataGridTextColumn Header="L" Binding="{Binding Losses}" Width="40" />
                        <DataGridTextColumn Header="GF" Binding="{Binding GoalsFor}" Width="46" />
                        <DataGridTextColumn Header="GA" Binding="{Binding GoalsAgainst}" Width="46" />
                        <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="50" />
                        <DataGridTextColumn Header="Pts" Binding="{Binding Points}" Width="52" />
                        <DataGridTemplateColumn Header="Last 5" Width="122">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding LastFive}"
                                                  ItemTemplate="{StaticResource LastFiveBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
