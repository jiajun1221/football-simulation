<UserControl x:Class="FootballSimulation.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>

        <Style x:Key="LeagueTableRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#102033" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelectedTeam}" Value="True">
                    <Setter Property="Background" Value="#FFF4CC" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="BorderBrush" Value="#F2B705" />
                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LastFiveBadgeTemplate">
            <Border Width="22"
                    Height="22"
                    CornerRadius="11"
                    Background="{Binding BadgeBrush}"
                    Margin="2,0">
                <TextBlock Text="{Binding ResultType}"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Club Dashboard"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="SelectedTeamTextBlock"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#1E528F"
                               Margin="0,0,0,24" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Upcoming Match"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#102033"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                x:Name="HomeAwayBadge"
                                CornerRadius="10"
                                Padding="10,4">
                            <TextBlock x:Name="HomeAwayBadgeTextBlock"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <Border Background="#F4F7FB"
                            BorderBrush="#DDE7F3"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock x:Name="UpcomingFixtureTextBlock"
                                       Foreground="#102033"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="VenueTextBlock"
                                       Foreground="#607187"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="PrepareMatchButton"
                            Content="Prepare Match"
                            Height="46"
                            Background="#102033"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="PrepareMatchButton_Click" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,28,0,0">
                    <TextBlock Text="Upcoming Club Fixtures"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,10" />
                    <ListBox x:Name="UpcomingFixturesListBox"
                             BorderThickness="0"
                             Background="Transparent" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="League Table"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#102033" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Last 5:"
                                   Foreground="#607187"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <Border Width="18" Height="18" CornerRadius="9" Background="#2FA84F" Margin="0,0,4,0">
                            <TextBlock Text="W" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#9AA3AF" Margin="0,0,4,0">
                            <TextBlock Text="D" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#D94343">
                            <TextBlock Text="L" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Champions League" Foreground="#465364" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#F97316" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Europa League" Foreground="#465364" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Conference qualifiers" Foreground="#465364" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" Background="#EF4444" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Relegation" Foreground="#465364" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <DataGrid x:Name="LeagueTableDataGrid"
                          Grid.Row="2"
                          Style="{StaticResource ModernDataGrid}"
                          RowStyle="{StaticResource LeagueTableRowStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="8">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ZoneBrush}"
                                            Width="5"
                                            HorizontalAlignment="Left"
                                            Margin="0,4" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="42" />
                        <DataGridTextColumn Header="Club" Binding="{Binding Club}" Width="*" />
                        <DataGridTextColumn Header="MP" Binding="{Binding Played}" Width="48" />
                        <DataGridTextColumn Header="W" Binding="{Binding Wins}" Width="42" />
                        <DataGridTextColumn Header="D" Binding="{Binding Draws}" Width="42" />
                        <DataGridTextColumn Header="L" Binding="{Binding Losses}" Width="42" />
                        <DataGridTextColumn Header="GF" Binding="{Binding GoalsFor}" Width="48" />
                        <DataGridTextColumn Header="GA" Binding="{Binding GoalsAgainst}" Width="48" />
                        <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="52" />
                        <DataGridTextColumn Header="Pts" Binding="{Binding Points}" Width="56" />
                        <DataGridTemplateColumn Header="Last 5" Width="135">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding LastFive}"
                                                  ItemTemplate="{StaticResource LastFiveBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
