<UserControl x:Class="FootballSimulation.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.12"
                                      Color="#233A55" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDashboardButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="#030712" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Style>
                            <Style TargetType="AccessText">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="PrimaryActionBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="16,0"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Direction="270"
                                                  Opacity="0.20"
                                                  Color="#102033" />
                            </Border.Effect>
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryActionBorder" Property="Background" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PrimaryActionBorder" Property="Background" Value="#000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryActionBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardWhiteActionButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#061226" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionBorder" Property="BorderBrush" Value="#60A5FA" />
                                <Setter TargetName="ActionBorder" Property="Background" Value="#F8FAFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource TableHeaderBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TableHeaderForeground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LeagueTableRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppPanelBackground}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelectedTeam}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableCurrentClubBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource TableCurrentClubForeground}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="LastFiveBadgeTemplate">
            <Border Width="20"
                    Height="20"
                    CornerRadius="10"
                    Background="{Binding BadgeBrush}"
                    Margin="2,0">
                <TextBlock Text="{Binding ResultType}"
                           Foreground="White"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="FixtureCardTemplate">
            <Border Background="{DynamicResource AppSecondaryCardBackground}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8,7"
                    Margin="0,0,6,0"
                    Width="108"
                    MinHeight="76"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{Binding HomeAwayBrush}"
                                CornerRadius="8"
                                Padding="5,2"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding HomeAwayText}"
                                       Foreground="{Binding HomeAwayForeground}"
                                       FontSize="7"
                                       FontWeight="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding RoundText}"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding OpponentLogoPath}"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OpponentShortName}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding VenueText}"
                                   FontSize="8"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UnavailablePlayerTemplate">
            <Border Background="#3A1117"
                    BorderBrush="#DC2626"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8"
                    Margin="0,0,0,6"
                    ToolTip="{Binding Tooltip}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Icon}"
                               Foreground="#FCA5A5"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Text}"
                               Foreground="#FEE2E2"
                               FontSize="11"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="2"
                            Background="#DC2626"
                            CornerRadius="8"
                            Padding="6,2"
                            Margin="8,0,0,0">
                        <TextBlock Text="{Binding BadgeText}"
                                   Foreground="White"
                                   FontSize="8"
                                   FontWeight="Black" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="FixtureCardItemStyle" TargetType="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="24"
          Background="{DynamicResource AppPageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="62" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="54"
                            Height="54"
                            CornerRadius="16"
                            Background="{DynamicResource AppPanelBackground}"
                            HorizontalAlignment="Left">
                        <Image x:Name="SelectedClubLogoImage"
                               Width="42"
                               Height="42"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="Club Dashboard"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}" />
                        <TextBlock x:Name="SelectedTeamTextBlock"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0,2,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="Season 2025/26"
                                       FontSize="12"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,10,0" />
                            <ItemsControl x:Name="ClubFormItemsControl"
                                          ItemTemplate="{StaticResource LastFiveBadgeTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{DynamicResource AppSecondaryCardBackground}"
                        CornerRadius="12"
                        Padding="12,8"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Position " Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock x:Name="PositionStatTextBlock" Foreground="{DynamicResource AppTextBrush}" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="  |  Points " Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock x:Name="PointsStatTextBlock" Foreground="{DynamicResource AppTextBrush}" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="  |  GD " Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock x:Name="GoalDifferenceStatTextBlock" Foreground="{DynamicResource AppTextBrush}" FontSize="15" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Upcoming Match"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                x:Name="HomeAwayBadge"
                                CornerRadius="9"
                                Padding="8,3">
                            <TextBlock x:Name="HomeAwayBadgeTextBlock"
                                       Foreground="White"
                                       FontSize="9"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <Border Background="{DynamicResource AppSecondaryCardBackground}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel HorizontalAlignment="Center">
                                    <Image x:Name="UpcomingHomeLogoImage" Width="34" Height="34" Stretch="Uniform" />
                                    <TextBlock x:Name="UpcomingHomeNameTextBlock"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="UpcomingRoundTextBlock"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="vs"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Image x:Name="UpcomingAwayLogoImage" Width="34" Height="34" Stretch="Uniform" />
                                    <TextBlock x:Name="UpcomingAwayNameTextBlock"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="VenueTextBlock"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Upcoming Fixtures"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Margin="0,0,0,6" />
                        <ItemsControl x:Name="UpcomingFixturesItemsControl"
                                      ItemTemplate="{StaticResource FixtureCardTemplate}"
                                      ItemContainerStyle="{StaticResource FixtureCardItemStyle}"
                                      VerticalAlignment="Stretch">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <Grid Margin="0,2,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PrepareMatchButton"
                                Grid.Row="0"
                                Grid.ColumnSpan="2"
                                Style="{StaticResource PrimaryDashboardButton}"
                                Content="⚽ Prepare Match"
                                Margin="0,0,0,8"
                                Click="PrepareMatchButton_Click" />

                        <Button Content="💾 Save Game"
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource DashboardWhiteActionButton}"
                                Margin="0,0,6,8"
                                Click="SaveGameButton_Click" />

                        <Button Content="👥 My Squad"
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource DashboardWhiteActionButton}"
                                Margin="0,0,0,8"
                                Click="MySquadButton_Click" />

                        <Button Content="💼 Transfer Market"
                                Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource DashboardWhiteActionButton}"
                                Margin="0,0,6,0"
                                Click="TransferMarketButton_Click" />

                        <Button Content="📊 Player Stats"
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource DashboardWhiteActionButton}"
                                Click="PlayerStatsButton_Click" />
                    </Grid>

                    <StackPanel x:Name="UnavailablePlayersPanel"
                                Margin="0,2,0,0"
                                Visibility="Collapsed">
                        <TextBlock Text="Unavailable"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6" />
                        <ItemsControl x:Name="UnavailablePlayersItemsControl"
                                      ItemTemplate="{StaticResource UnavailablePlayerTemplate}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="League Table"
                               FontSize="25"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Last 5:"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,8,0" />
                        <Border Width="18" Height="18" CornerRadius="9" Background="#2FA84F" Margin="0,0,4,0">
                            <TextBlock Text="W" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#9AA3AF" Margin="0,0,4,0">
                            <TextBlock Text="D" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="18" Height="18" CornerRadius="9" Background="#D94343">
                            <TextBlock Text="L" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#3B82F6" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Champions League" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#F97316" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Europa League" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                        <Border Width="10" Height="10" Background="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Conference qualifiers" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" Background="#EF4444" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="Relegation" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <DataGrid x:Name="LeagueTableDataGrid"
                          Grid.Row="2"
                          Style="{StaticResource ModernDataGrid}"
                          RowStyle="{StaticResource LeagueTableRowStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="9">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding ZoneBrush}"
                                            Width="5"
                                            HorizontalAlignment="Left"
                                            Margin="0,5" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="38" />
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding LogoPath}"
                                           Width="26"
                                           Height="26"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Club" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Club}"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="MP" Binding="{Binding Played}" Width="44" />
                        <DataGridTextColumn Header="W" Binding="{Binding Wins}" Width="40" />
                        <DataGridTextColumn Header="D" Binding="{Binding Draws}" Width="40" />
                        <DataGridTextColumn Header="L" Binding="{Binding Losses}" Width="40" />
                        <DataGridTextColumn Header="GF" Binding="{Binding GoalsFor}" Width="46" />
                        <DataGridTextColumn Header="GA" Binding="{Binding GoalsAgainst}" Width="46" />
                        <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="50" />
                        <DataGridTextColumn Header="Pts" Binding="{Binding Points}" Width="52" />
                        <DataGridTemplateColumn Header="Last 5" Width="122">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding LastFive}"
                                                  ItemTemplate="{StaticResource LastFiveBadgeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
