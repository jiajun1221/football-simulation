<UserControl x:Class="FootballSimulation.Wpf.Views.HalfTimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="HalfTimePlayerCardTemplate">
            <Border Width="128"
                    Height="76"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding PlayerName}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="#102033"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Grid.Column="1"
                                Background="#102033"
                                CornerRadius="8"
                                Padding="5,2">
                            <TextBlock Text="{Binding RatingText}"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding MatchStatsText}"
                               FontSize="9"
                               Foreground="#607187"
                               Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />

                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Height="7"
                                Background="#DDE5EF"
                                CornerRadius="4"
                                VerticalAlignment="Center">
                            <Border Width="{Binding FatigueBarWidth}"
                                    Background="{Binding FatigueBrush}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding FatigueText}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#465364"
                                   Margin="6,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Half Time Adjustments"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock x:Name="ScoreTextBlock"
                               Foreground="#DDF7E8"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#16894A"
                        BorderBrush="#B8F2CD"
                        BorderThickness="2"
                        CornerRadius="18">
                    <Grid>
                        <Line X1="0" Y1="260" X2="900" Y2="260" Stroke="#8FE2AE" Opacity="0.35" />
                        <Ellipse Width="130"
                                 Height="130"
                                 Stroke="#8FE2AE"
                                 StrokeThickness="2"
                                 Opacity="0.45"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                        <Canvas x:Name="PitchCanvas"
                                Margin="18"
                                SizeChanged="PitchCanvas_SizeChanged" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="18"
                Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Second-Half Setup"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,14" />

                    <TextBlock Text="Formation" FontWeight="SemiBold" />
                    <ComboBox x:Name="FormationComboBox"
                              Height="36"
                              Margin="0,6,0,16"
                              SelectionChanged="FormationComboBox_SelectionChanged" />

                    <TextBlock Text="Tactics"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,10" />

                    <TextBlock Text="Mentality" FontWeight="SemiBold" />
                    <ComboBox x:Name="MentalityComboBox"
                              Height="34"
                              Margin="0,6,0,12" />

                    <TextBlock Text="Pressing Intensity" FontWeight="SemiBold" />
                    <Slider x:Name="PressingSlider" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Width" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <Slider x:Name="WidthSlider" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Tempo" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <Slider x:Name="TempoSlider" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Defensive Line" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <Slider x:Name="DefensiveLineSlider" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Selected Player"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,18,0,8" />
                    <Border Background="#F3F6FA"
                            CornerRadius="12"
                            Padding="12">
                        <TextBlock x:Name="SelectedPlayerTextBlock"
                                   Text="Select a player on the pitch."
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Substitutes"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,18,0,8" />
                    <TextBlock x:Name="SubstituteStatusTextBlock"
                               Foreground="#607187"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <ListBox x:Name="SubstituteListBox"
                             Height="150"
                             SelectionChanged="SubstituteListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="#102033"
                                               TextTrimming="CharacterEllipsis" />

                                    <Border Grid.Column="1"
                                            Background="#E9EEF5"
                                            CornerRadius="7"
                                            Padding="6,2"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Position}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="#102033" />
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="#102033"
                                            CornerRadius="7"
                                            Padding="7,2"
                                            Margin="6,0,0,0">
                                        <TextBlock Text="{Binding OverallRating}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="White" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:Name="SwapButton"
                            Content="Swap Selected Player"
                            Height="38"
                            Margin="0,12,0,18"
                            IsEnabled="False"
                            Click="SwapButton_Click" />

                    <Button Content="Start Second Half"
                            Height="44"
                            FontWeight="SemiBold"
                            Click="StartSecondHalfButton_Click" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
