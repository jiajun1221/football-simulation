<UserControl x:Class="FootballSimulation.Wpf.Views.HalfTimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="PitchPlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="1,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CardStatusBadgeTemplate">
            <Border MinWidth="14"
                    Height="14"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontSize="7.5"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PitchPlayerCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding MutedForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding OverallForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:FlagBadge FlagSource="{Binding FlagImagePath}"
                                            ToolTip="{Binding NationalityName}"
                                            Width="20"
                                            Height="14"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PlayerName}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding WorkloadRiskBrush}"
                                CornerRadius="7"
                                Padding="3,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding WorkloadRiskTooltip}">
                            <TextBlock Text="{Binding WorkloadRiskText}"
                                       FontFamily="Segoe UI Emoji"
                                       Foreground="{Binding WorkloadRiskForeground}"
                                       FontSize="7"
                                       FontWeight="Black" />
                        </Border>
                        <Border Background="{Binding FatigueWarningBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding FatigueWarningTooltip}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FatigueWarningText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding FatigueWarningText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding FormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding FormBadgeText}"
                                       Foreground="{Binding FormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CardStatusBadges}"
                                      ItemTemplate="{StaticResource CardStatusBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CardStatusBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubstituteCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="SubstituteCard_PreviewMouseLeftButtonDown"
                    MouseMove="SubstituteCard_MouseMove"
                    PreviewDragEnter="SubstituteCard_DragEnter"
                    PreviewDragOver="SubstituteCard_DragOver"
                    PreviewDragLeave="SubstituteCard_DragLeave"
                    PreviewDrop="SubstituteCard_Drop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding TextForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <controls:FlagBadge FlagSource="{Binding FlagImagePath}"
                                            ToolTip="{Binding NationalityName}"
                                            Width="20"
                                            Height="14"
                                            Margin="0,0,4,0"
                                            VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding WorkloadRiskBrush}"
                                CornerRadius="7"
                                Padding="3,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding WorkloadRiskTooltip}">
                            <TextBlock Text="{Binding WorkloadRiskText}"
                                       FontFamily="Segoe UI Emoji"
                                       Foreground="{Binding WorkloadRiskForeground}"
                                       FontSize="7"
                                       FontWeight="Black" />
                        </Border>
                        <Border Background="{Binding FatigueWarningBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding FatigueWarningTooltip}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FatigueWarningText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding FatigueWarningText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding BenchFormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding BenchFormBadgeText}"
                                       Foreground="{Binding BenchFormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding CardStatusBadges}"
                                      ItemTemplate="{StaticResource CardStatusBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CardStatusBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid x:Name="MainRootGrid"
          Background="{DynamicResource AppPageBackground}"
          Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="SetupTitleTextBlock"
                               Text="Half-Time Setup"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Black"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="ScoreTextBlock"
                               Foreground="#DDF7E8"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#16894A"
                            BorderBrush="#B8F2CD"
                            BorderThickness="2"
                            CornerRadius="18">
                        <Grid>
                            <Line X1="0" Y1="0" X2="900" Y2="0" Stroke="#8FE2AE" Opacity="0.45" />
                            <Line X1="0" Y1="260" X2="900" Y2="260" Stroke="#8FE2AE" Opacity="0.35" />
                            <Ellipse Width="110"
                                     Height="110"
                                     Stroke="#8FE2AE"
                                     StrokeThickness="2"
                                     Opacity="0.45"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Canvas x:Name="PitchCanvas"
                                    Margin="16"
                                    SizeChanged="PitchCanvas_SizeChanged" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="18,0,0,18"
                                    Padding="10"
                                    CornerRadius="13"
                                    Background="{DynamicResource TacticalFloatingPanelBackground}"
                                    BorderBrush="{DynamicResource TacticalFloatingPanelBorder}"
                                    BorderThickness="1.2"
                                    IsHitTestVisible="False"
                                    MaxWidth="300">
                                <Border.Effect>
                                    <DropShadowEffect Color="#071226"
                                                      BlurRadius="16"
                                                      ShadowDepth="2"
                                                      Opacity="0.22" />
                                </Border.Effect>
                                <Grid>
                                    <TextBlock x:Name="SelectedPlayerEmptyTextBlock"
                                               Text="Select a player on the pitch."
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               TextWrapping="Wrap" />

                                    <Grid x:Name="SelectedPlayerCard"
                                          Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                <controls:FlagBadge x:Name="SelectedPlayerFlagImage"
                                                                    Width="20"
                                                                    Height="14"
                                                                    Margin="0,0,5,0"
                                                                    VerticalAlignment="Center" />
                                                <TextBlock x:Name="SelectedPlayerNameTextBlock"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontSize="14"
                                                           FontWeight="Black"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border x:Name="SelectedPlayerOvrBadgeBorder"
                                                        CornerRadius="10"
                                                        Padding="7,3"
                                                        Margin="0,0,4,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="SelectedPlayerOvrBadgeTextBlock"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="Black" />
                                                </Border>
                                                <Border x:Name="SelectedPlayerFormBadgeBorder"
                                                        CornerRadius="10"
                                                        Padding="8,3"
                                                        Background="{DynamicResource TacticalOptionBackground}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="SelectedPlayerFormBadgeTextBlock"
                                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                                               FontSize="10"
                                                               FontWeight="Bold" />
                                                </Border>
                                                <ItemsControl x:Name="SelectedPlayerTraitItemsControl"
                                                              ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                                              Margin="4,0,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                                <ItemsControl x:Name="SelectedPlayerCardStatusItemsControl"
                                                              ItemTemplate="{StaticResource CardStatusBadgeTemplate}"
                                                              Margin="2,0,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock x:Name="SelectedPlayerMetaTextBlock"
                                                   Grid.Row="1"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Margin="0,1,0,6" />

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerLeftStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerLeftStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerLeftStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerLeftStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerLeftStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerLeftStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerRightStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerRightStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerRightStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerRightStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="SelectedPlayerRightStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                                    <TextBlock x:Name="SelectedPlayerRightStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Visibility="Collapsed">
                                                <TextBlock x:Name="SelectedPlayerLeftStat4Label" />
                                                <TextBlock x:Name="SelectedPlayerLeftStat4Value" />
                                                <TextBlock x:Name="SelectedPlayerLeftStat5Label" />
                                                <TextBlock x:Name="SelectedPlayerLeftStat5Value" />
                                                <TextBlock x:Name="SelectedPlayerLeftStat6Label" />
                                                <TextBlock x:Name="SelectedPlayerLeftStat6Value" />
                                                <TextBlock x:Name="SelectedPlayerRightStat4Label" />
                                                <TextBlock x:Name="SelectedPlayerRightStat4Value" />
                                                <TextBlock x:Name="SelectedPlayerRightStat5Label" />
                                                <TextBlock x:Name="SelectedPlayerRightStat5Value" />
                                                <TextBlock x:Name="SelectedPlayerRightStat6Label" />
                                                <TextBlock x:Name="SelectedPlayerRightStat6Value" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,18,18"
                                    Padding="10,8"
                                    CornerRadius="13"
                                    Background="{DynamicResource TacticalFloatingPanelBackground}"
                                    BorderBrush="{DynamicResource TacticalFloatingPanelBorder}"
                                    BorderThickness="1.2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#071226"
                                                      BlurRadius="16"
                                                      ShadowDepth="2"
                                                      Opacity="0.26" />
                                </Border.Effect>
                                <StackPanel Width="168">
                                    <TextBlock Text="Formation ⚽"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Margin="0,0,0,4" />
                                    <ComboBox x:Name="FormationComboBox"
                                              Height="28"
                                              FontSize="12"
                                              SelectionChanged="FormationComboBox_SelectionChanged">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10"
                                                                   FontWeight="Black"
                                                                   Foreground="#2563EB"
                                                                   Margin="6,6,0,3" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0F6D39"
                            BorderBrush="#B8F2CD"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Substitutes"
                                           Foreground="White"
                                           FontSize="17"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="SubstitutionStatusTextBlock"
                                           Grid.Column="1"
                                           Foreground="#DDF7E8"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <ListBox x:Name="SubstituteListBox"
                                     Grid.Row="1"
                                     Margin="0,10,0,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     AllowDrop="True"
                                     PreviewDragEnter="SubstituteListBox_DragEnter"
                                     PreviewDragOver="SubstituteListBox_DragOver"
                                     PreviewDragLeave="SubstituteListBox_DragLeave"
                                     PreviewDrop="SubstituteListBox_Drop"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="True">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Opacity" Value="0.94" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="SubstituteCardTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource AppCardBackground}"
                CornerRadius="18"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Setup"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppTextBrush}"
                           Margin="0,0,0,8" />

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tactics"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TacticalInsightInfoIcon"
                               Grid.Column="1"
                               Text="i"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               ToolTipService.ShowDuration="30000" />
                </Grid>

                <controls:TacticalSettingsPanel x:Name="TacticalSettingsPanel"
                                                PanelMaxHeight="350"
                                                TacticsChanged="TacticalSettingsPanel_TacticsChanged" />

                <Button x:Name="StartSecondHalfButton"
                        Content="Start Second Half"
                        Style="{StaticResource PrimaryTextButton}"
                        Height="40"
                        Margin="0,8,0,0"
                        FontWeight="SemiBold"
                        Click="StartSecondHalfButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
