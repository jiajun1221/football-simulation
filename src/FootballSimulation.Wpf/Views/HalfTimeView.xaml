<UserControl x:Class="FootballSimulation.Wpf.Views.HalfTimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="PitchPlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="1,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PitchPlayerCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding MutedForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding OverallForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding PlayerName}"
                               Foreground="{Binding TextForeground}"
                               FontSize="9.2"
                               FontWeight="Black"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding FormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding FormBadgeText}"
                                       Foreground="{Binding FormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubstituteCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="SubstituteCard_PreviewMouseLeftButtonDown"
                    MouseMove="SubstituteCard_MouseMove"
                    PreviewDragEnter="SubstituteCard_DragEnter"
                    PreviewDragOver="SubstituteCard_DragOver"
                    PreviewDragLeave="SubstituteCard_DragLeave"
                    PreviewDrop="SubstituteCard_Drop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding TextForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Name}"
                               Foreground="{Binding TextForeground}"
                               FontSize="9.2"
                               FontWeight="Black"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding BenchFormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding BenchFormBadgeText}"
                                       Foreground="{Binding BenchFormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="MainRootGrid"
          Background="{DynamicResource AppPageBackground}"
          Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="ScoreTextBlock"
                               Foreground="#DDF7E8"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#16894A"
                            BorderBrush="#B8F2CD"
                            BorderThickness="2"
                            CornerRadius="18">
                        <Grid>
                            <Line X1="0" Y1="0" X2="900" Y2="0" Stroke="#8FE2AE" Opacity="0.45" />
                            <Line X1="0" Y1="260" X2="900" Y2="260" Stroke="#8FE2AE" Opacity="0.35" />
                            <Ellipse Width="110"
                                     Height="110"
                                     Stroke="#8FE2AE"
                                     StrokeThickness="2"
                                     Opacity="0.45"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Canvas x:Name="PitchCanvas"
                                    Margin="16"
                                    SizeChanged="PitchCanvas_SizeChanged" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0F6D39"
                            BorderBrush="#B8F2CD"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Substitutes"
                                           Foreground="White"
                                           FontSize="17"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="SubstitutionStatusTextBlock"
                                           Grid.Column="1"
                                           Foreground="#DDF7E8"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <ListBox x:Name="SubstituteListBox"
                                     Grid.Row="1"
                                     Margin="0,10,0,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     AllowDrop="True"
                                     PreviewDragEnter="SubstituteListBox_DragEnter"
                                     PreviewDragOver="SubstituteListBox_DragOver"
                                     PreviewDragLeave="SubstituteListBox_DragLeave"
                                     PreviewDrop="SubstituteListBox_Drop"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="True">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,6" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Opacity" Value="0.94" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="SubstituteCardTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource AppCardBackground}"
                CornerRadius="18"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Setup"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppTextBrush}"
                           Margin="0,0,0,8" />

                <TextBlock Text="Selected Player"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppTextBrush}"
                           Margin="0,0,0,5" />
                <Border Background="{DynamicResource AppPanelBackground}"
                        CornerRadius="12"
                        Padding="9"
                        Margin="0,0,0,10">
                    <Grid>
                        <TextBlock x:Name="SelectedPlayerEmptyTextBlock"
                                   Text="Select a player on the pitch."
                                   FontSize="11"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextWrapping="Wrap" />

                        <Grid x:Name="SelectedPlayerCard"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="SelectedPlayerNameTextBlock"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           FontSize="14"
                                           FontWeight="Black"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border x:Name="SelectedPlayerFormBadgeBorder"
                                            CornerRadius="10"
                                            Padding="8,3"
                                            Background="{DynamicResource AppSecondaryCardBackground}"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#203B2D"
                                                              BlurRadius="6"
                                                              ShadowDepth="1"
                                                              Opacity="0.18" />
                                        </Border.Effect>
                                        <TextBlock x:Name="SelectedPlayerFormBadgeTextBlock"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <ItemsControl x:Name="SelectedPlayerTraitItemsControl"
                                                  ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                                  Margin="4,0,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="SelectedPlayerMetaTextBlock"
                                       Grid.Row="1"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,1,0,6" />

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat4Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat4Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat5Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat5Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat6Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat6Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat4Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat4Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat5Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat5Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat6Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat6Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Formation"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{DynamicResource AppTextBrush}"
                           Margin="0,0,0,1" />
                <ComboBox x:Name="FormationComboBox"
                          Height="30"
                          Margin="0,3,0,8"
                          SelectionChanged="FormationComboBox_SelectionChanged" />

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Tactics"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TacticalInsightInfoIcon"
                               Grid.Column="1"
                               Text="i"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="13"
                               FontWeight="Bold"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               ToolTipService.ShowDuration="30000" />
                </Grid>

                <TextBlock Text="Mentality" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" />
                <ComboBox x:Name="MentalityComboBox"
                          Height="30"
                          Margin="0,3,0,7"
                          SelectionChanged="TacticsControl_Changed" />

                <TextBlock Text="Pressing Intensity" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" />
                <Slider x:Name="PressingSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                <TextBlock Text="Width" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="0,3,0,0" />
                <Slider x:Name="WidthSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                <TextBlock Text="Tempo" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="0,3,0,0" />
                <Slider x:Name="TempoSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                <TextBlock Text="Defensive Line" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}" Margin="0,3,0,0" />
                <Slider x:Name="DefensiveLineSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                <Button Content="Start Second Half"
                        Style="{StaticResource PrimaryTextButton}"
                        Height="40"
                        Margin="0,8,0,0"
                        FontWeight="SemiBold"
