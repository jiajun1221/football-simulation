<UserControl x:Class="FootballSimulation.Wpf.Views.LeaguePlayerStatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="StatsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource AppSecondaryCardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatsGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="54" />
            <Setter Property="ColumnHeaderHeight" Value="42" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource TableHeaderBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TableHeaderForeground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatsLeftTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="LineHeight" Value="16" />
        </Style>

        <Style x:Key="StatsCenterTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StatsLeftTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatsBoldLeftTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StatsLeftTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="StatsGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppPanelBackground}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelectedClubPlayer}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableCurrentClubBackground}" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Current Season Player Stats"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="28"
                           FontWeight="Black" />
                <TextBlock x:Name="LeagueSubtitleTextBlock"
                           Text="League: -"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Content="Back to Dashboard"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Height="38"
                    MinWidth="158"
                    Padding="18,0"
                    Margin="0,0,92,0"
                    Background="#0F172A"
                    Foreground="#FFFFFF"
                    BorderThickness="0"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="BackButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="13"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackButtonBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource StatsCard}"
                Margin="0,0,0,16">
            <WrapPanel>
                <Button x:Name="GoalsButton" Content="Goals" Tag="Goals" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="AssistsButton" Content="Assists" Tag="Assists" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="SavesButton" Content="Saves" Tag="Saves" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="CleanSheetsButton" Content="Clean Sheets" Tag="CleanSheets" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="YellowCardsButton" Content="Yellow Cards" Tag="YellowCards" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="RedCardsButton" Content="Red Cards" Tag="RedCards" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="RatingsButton" Content="Player Ratings" Tag="Ratings" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
                <Button x:Name="AppearancesButton" Content="Appearances" Tag="Appearances" Style="{StaticResource CategoryButtonStyle}" Click="CategoryButton_Click" />
            </WrapPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource StatsCard}">
            <DataGrid x:Name="StatsDataGrid"
                      Style="{StaticResource StatsGridStyle}"
                      RowStyle="{StaticResource StatsGridRowStyle}"
                      ItemsSource="{Binding}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="62" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="PlayerColumn" Header="Player" Binding="{Binding PlayerName}" Width="2*" ElementStyle="{StaticResource StatsBoldLeftTextStyle}" />
                    <DataGridTemplateColumn Header="" Width="52">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Height="54"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center">
                                    <Image Source="{Binding ClubLogoPath}"
                                           Width="28"
                                           Height="28"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Club" Binding="{Binding TeamName}" Width="1.5*" ElementStyle="{StaticResource StatsBoldLeftTextStyle}" />
                    <DataGridTextColumn x:Name="PositionColumn" Header="Position" Binding="{Binding PositionText}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="GoalsColumn" Header="Goals" Binding="{Binding Goals}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="AssistsColumn" Header="Assists" Binding="{Binding Assists}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="SavesColumn" Header="Saves" Binding="{Binding Saves}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="GoalsConcededColumn" Header="Goals Conceded" Binding="{Binding GoalsConceded}" Width="130" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="CleanSheetsColumn" Header="Clean Sheets" Binding="{Binding CleanSheets}" Width="120" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="YellowCardsColumn" Header="Yellow" Binding="{Binding YellowCards}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="RedCardsColumn" Header="Red" Binding="{Binding RedCards}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="MatchesColumn" Header="Matches" Binding="{Binding Matches}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="StartsColumn" Header="Starts" Binding="{Binding Starts}" Width="80" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTextColumn x:Name="MinutesColumn" Header="Minutes" Binding="{Binding MinutesPlayed}" Width="90" ElementStyle="{StaticResource StatsCenterTextStyle}" />
                    <DataGridTemplateColumn x:Name="RatingColumn" Header="Average Rating" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Height="54"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center">
                                    <Border MinWidth="46"
                                            Height="34"
                                            Background="{Binding RatingBackground}"
                                            CornerRadius="10"
                                            Padding="8,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AverageRatingText}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Form" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Height="54"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center">
                                    <Border MinWidth="74"
                                            Height="34"
                                            Background="{Binding FormBadgeBackground}"
                                            CornerRadius="10"
                                            Padding="8,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FormBadgeText}"
                                                   Foreground="{Binding FormBadgeForeground}"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
