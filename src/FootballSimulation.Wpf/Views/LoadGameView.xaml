<UserControl x:Class="FootballSimulation.Wpf.Views.LoadGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="LoadSlotPrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoadSlotSecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="{DynamicResource AppSecondaryCardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SaveSlotCardTemplate">
            <Border Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="22"
                    Margin="10"
                    MinWidth="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding SlotTitle}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}" />

                    <StackPanel Grid.Row="1" Margin="0,18,0,18">
                        <Border Width="82"
                                Height="82"
                                CornerRadius="41"
                                Background="{DynamicResource AppPanelBackground}"
                                HorizontalAlignment="Center"
                                Visibility="{Binding LogoVisibility}">
                            <Image Source="{Binding LogoPath}"
                                   Width="62"
                                   Height="62"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="{Binding ClubName}"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,8" />

                        <TextBlock Text="{Binding SeasonText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,4" />

                        <TextBlock Text="{Binding RoundText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center" />

                        <TextBlock Text="{Binding PositionText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,4,0,0" />

                        <TextBlock Text="{Binding PointsText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   Margin="0,4,0,0" />

                        <TextBlock Text="{Binding SavedAtText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,14,0,0" />

                        <TextBlock Text="{Binding WarningText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#EF4444"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding WarningVisibility}"
                                   Margin="0,14,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Load"
                                Style="{StaticResource LoadSlotPrimaryButton}"
                                Width="92"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanLoad}"
                                Visibility="{Binding LoadVisibility}"
                                Click="LoadButton_Click" />
                        <Button Content="Delete"
                                Style="{StaticResource LoadSlotSecondaryButton}"
                                Width="92"
                                Visibility="{Binding DeleteVisibility}"
                                Click="DeleteButton_Click" />
                        <TextBlock Text="[Empty]"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Visibility="{Binding EmptyVisibility}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Load Game"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="Choose one of three save slots to continue your Premier League season."
                       FontSize="14"
                       Foreground="{DynamicResource AppMutedTextBrush}"
                       Margin="0,6,0,0" />
        </StackPanel>

        <ItemsControl x:Name="SaveSlotsItemsControl"
                      Grid.Row="1"
                      ItemTemplate="{StaticResource SaveSlotCardTemplate}"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Button Grid.Row="2"
                Style="{StaticResource LoadSlotSecondaryButton}"
                Content="Back"
                Width="130"
                Height="44"
                HorizontalAlignment="Left"
                Click="BackButton_Click" />
    </Grid>
</UserControl>
