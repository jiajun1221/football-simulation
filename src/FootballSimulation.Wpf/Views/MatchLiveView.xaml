<UserControl x:Class="FootballSimulation.Wpf.Views.MatchLiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FootballSimulation.Wpf.Models"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="1,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CardStatusBadgeTemplate">
            <Border MinWidth="14"
                    Height="14"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontSize="7.5"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PitchPlayerIconTemplate" DataType="{x:Type models:LivePlayerIconViewModel}">
            <Grid Width="72"
                  Height="76"
                  Cursor="Hand"
                  AllowDrop="True"
                  PreviewMouseMove="PitchPlayerIcon_PreviewMouseMove"
                  MouseLeftButtonUp="PitchPlayerIcon_MouseLeftButtonUp"
                  Drop="PitchPlayerIcon_Drop"
                  ToolTip="{Binding DetailText}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="16" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{Binding RatingBadgeBackground}"
                        BorderBrush="{Binding RatingBadgeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding LiveStats.RatingDisplay}"
                               Foreground="{Binding RatingBadgeForeground}"
                               FontSize="8"
                               FontWeight="Bold" />
                </Border>

                <Grid Grid.Row="1"
                      Width="42"
                      Height="3"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Border Background="#66E5E7EB"
                            CornerRadius="2" />
                    <Border Width="{Binding LiveStats.StaminaBarWidth, Mode=OneWay}"
                            Background="{Binding LiveStats.StaminaBrush, Mode=OneWay}"
                            CornerRadius="2"
                            HorizontalAlignment="Left" />
                </Grid>

                <Ellipse Grid.Row="2"
                         Width="40"
                         Height="40"
                         Stroke="{Binding SelectionBrush}"
                         StrokeThickness="{Binding SelectionThickness}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />

                <Border Grid.Row="2"
                        Width="34"
                        Height="34"
                        CornerRadius="17"
                        Background="{Binding IconBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Foreground="{Binding IconForeground}"
                               FontSize="12"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding ShirtNumberText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShirtNumberText}" Value="">
                                        <Setter Property="Text" Value="{Binding Initials}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <Border Grid.Row="2"
                        Width="20"
                        Height="20"
                        CornerRadius="10"
                        Background="{Binding BallIndicatorBrush}"
                        BorderBrush="{Binding BallIndicatorBorderBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,8,1"
                        ToolTip="{Binding BallIndicatorTooltip}"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <RotateTransform />
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasBallIndicator}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:1.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                    <TextBlock Text="{Binding BallIndicatorText}"
                               Foreground="{Binding BallIndicatorForeground}"
                               FontFamily="Segoe UI Emoji"
                               FontSize="11"
                               FontWeight="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center" />
                </Border>

                <Border Grid.Row="2"
                        Background="#B42318"
                        CornerRadius="8"
                        Padding="5,1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,0,10,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PendingSubOutBadgeText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding PendingSubOutBadgeText}"
                               Foreground="White"
                               FontSize="9"
                               FontWeight="Black" />
                </Border>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,1,0,0">
                    <Border Background="#7CFC9A" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GoalBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding GoalBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="#166534" />
                    </Border>
                    <Border Background="{DynamicResource FeedChanceIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AssistBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding AssistBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedChanceIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedDefensiveIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DefensiveBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding DefensiveBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedDefensiveIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedChanceIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ErrorBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedChanceIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedDefensiveIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SaveBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedDefensiveIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedFoulIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding YellowBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding YellowBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedFoulIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedAttackIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RedBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding RedBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedAttackIconForeground}" />
                    </Border>
                    <Border Background="{DynamicResource FeedAttackIconBackground}" CornerRadius="6" Padding="3,0" Margin="1,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InjuryBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding InjuryBadgeText}" FontFamily="Segoe UI Emoji" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource FeedAttackIconForeground}" />
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SubstitutionPlayerTemplate">
            <StackPanel Width="142"
                        Margin="0,0,0,7">
                <Grid Margin="0,0,0,3">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PendingPlayerOutName}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{DynamicResource FeedAttackBackground}"
                            BorderBrush="{DynamicResource FeedAttackBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="6,2"
                            Margin="0,0,5,0">
                        <TextBlock Foreground="{DynamicResource FeedAttackLabelForeground}"
                                   FontSize="9"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding PendingPlayerOutName}" />
                            <Run Text=" ↓" />
                        </TextBlock>
                    </Border>

                    <Button Grid.Column="1"
                            Width="22"
                            Height="22"
                            Content="X"
                            Foreground="{DynamicResource FeedAttackLabelForeground}"
                            Background="{DynamicResource FeedAttackBackground}"
                            BorderBrush="{DynamicResource FeedAttackBorder}"
                            BorderThickness="1"
                            FontSize="10"
                            FontWeight="Black"
                            Padding="0"
                            ToolTip="Cancel pending substitution"
                            PreviewMouseLeftButtonDown="CancelPendingSubstitutionButton_PreviewMouseLeftButtonDown"
                            Click="CancelPendingSubstitutionButton_Click" />
                </Grid>

                <Border MinHeight="70"
                        Padding="6"
                        CornerRadius="8"
                        Background="{Binding CardBackground}"
                        BorderBrush="{Binding CardBorderBrush}"
                        BorderThickness="1"
                        PreviewMouseMove="BenchPlayerCard_PreviewMouseMove">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding FlagImagePath}"
                                   ToolTip="{Binding NationalityName}"
                                   Width="14"
                                   Height="10"
                                   Stretch="UniformToFill"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayName}"
                                       Foreground="{Binding NameForeground}"
                                       FontSize="9.2"
                                       FontWeight="Black"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding ShirtNumberText}"
                                       Foreground="{Binding TextForeground}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding OverallText}"
                                           Foreground="{Binding TextForeground}"
                                           FontSize="9.5"
                                           FontWeight="Black" />
                                <TextBlock Text="{Binding GrowthText}"
                                           Foreground="#16A34A"
                                           FontSize="7.5"
                                           FontWeight="Black"
                                           Margin="4,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{Binding PositionBackground}"
                                    CornerRadius="7"
                                    Padding="5,1">
                                <TextBlock Text="{Binding Position}"
                                           Foreground="{Binding PositionForeground}"
                                           FontSize="7.5"
                                           FontWeight="Black" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Margin="0,4,0,0">
                            <Border Background="{Binding FormBadgeBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,2,0">
                                <TextBlock Text="{Binding FormBadgeText}"
                                           Foreground="{Binding FormBadgeForeground}"
                                           FontSize="7"
                                           FontWeight="Bold" />
                            </Border>
                            <ItemsControl ItemsSource="{Binding TraitBadges}"
                                          ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding CardStatusBadges}"
                                          ItemTemplate="{StaticResource CardStatusBadgeTemplate}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CardStatusBadges.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <ProgressBar Grid.Row="3"
                                     Height="5"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Stamina}"
                                     Foreground="{Binding StaminaBrush}"
                                     Background="{DynamicResource AppBorderBrush}"
                                     BorderThickness="0"
                                     Margin="0,5,0,0" />
                    </Grid>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="LiveMatchRootGrid"
          Margin="20"
          Background="{DynamicResource AppPageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LiveTrackerColumnDefinition" Width="320" />
            <ColumnDefinition x:Name="FullMatchColumnDefinition" Width="*" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="LiveTrackerPanel"
              Grid.Column="0"
              Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="ScoreboardPanel"
                    Background="#071226"
                    BorderBrush="#243247"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,0,12">
                <Grid>
                    <Button x:Name="CompactViewToggleButton"
                            Width="30"
                            Height="30"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Panel.ZIndex="2"
                            Content="⤢"
                            ToolTip="Compact View"
                            FontFamily="Segoe UI Symbol"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#F8FAFC"
                            Background="#263B58"
                            BorderBrush="#4B6383"
                            BorderThickness="1"
                            Click="CompactViewToggleButton_Click" />
                    <StackPanel>
                    <TextBlock x:Name="PhaseTextBlock"
                               Foreground="#F8FAFC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />

                    <TextBlock x:Name="VenueTextBlock"
                               Foreground="#F8FAFC"
                               FontSize="11"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,4,0,0" />

                    <Grid x:Name="ScoreboardScoreGrid"
                          HorizontalAlignment="Stretch"
                          Margin="0,6,0,0"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ScoreboardScaleTransform" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="HomeScorePanel"
                                Grid.Column="0"
                                Width="136"
                                Height="78"
                                Background="#172A45"
                                CornerRadius="9"
                                Padding="6"
                                HorizontalAlignment="Left">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="HomeTeamNameTextBlock"
                                           Foreground="#DCE8F7"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="HomeScoreTextBlock"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Black"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ScoreSeparatorTextBlock"
                                   Grid.Column="1"
                                   Text="-"
                                   Foreground="#F8FAFC"
                                   FontSize="22"
                                   FontWeight="Black"
                                   VerticalAlignment="Center"
                                   Margin="6,0" />

                        <Border x:Name="AwayScorePanel"
                                Grid.Column="2"
                                Width="136"
                                Height="78"
                                Background="#172A45"
                                CornerRadius="9"
                                Padding="6"
                                HorizontalAlignment="Right">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="AwayTeamNameTextBlock"
                                           Foreground="#DCE8F7"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="AwayScoreTextBlock"
                                           Foreground="White"
                                           FontSize="34"
                                           FontWeight="Black"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <StackPanel x:Name="CompactScoreControlsPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Visibility="Collapsed">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="34" />
                                <Setter Property="Height" Value="30" />
                                <Setter Property="Margin" Value="2" />
                                <Setter Property="Background" Value="#263B58" />
                                <Setter Property="Foreground" Value="#F8FAFC" />
                                <Setter Property="BorderBrush" Value="#4B6383" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="FontFamily" Value="Segoe UI Symbol" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </StackPanel.Resources>
                        <Button x:Name="CompactPauseResumeButton"
                                Content="&#x23F8;"
                                ToolTip="Pause / Resume"
                                Click="PauseResumeButton_Click" />
                        <Button x:Name="CompactDecreaseSpeedButton"
                                Content="&#x23EA;"
                                ToolTip="Slower"
                                Click="DecreaseSpeedButton_Click" />
                        <Border Width="54"
                                Height="30"
                                CornerRadius="10"
                                Background="#DCEBFF"
                                Margin="3"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CompactSpeedLevelTextBlock"
                                       Text="1x"
                                       Foreground="#071226"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Button x:Name="CompactIncreaseSpeedButton"
                                Content="&#x23E9;"
                                ToolTip="Faster"
                                Click="IncreaseSpeedButton_Click" />
                        <Button x:Name="CompactContinueButton"
                                Content="Continue"
                                Width="82"
                                FontFamily="Segoe UI"
                                FontSize="11"
                                ToolTip="Continue"
                                Visibility="Collapsed"
                                IsEnabled="False"
                                Click="ContinueButton_Click" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="FeedPanel"
                    Grid.Row="1"
                    Background="{DynamicResource AppCardBackground}"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Live Match Feed"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />

                        <Border x:Name="LiveStatusBadge"
                                Grid.Column="1"
                                Background="{DynamicResource AppPanelBackground}"
                                CornerRadius="12"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LiveStatusIconTextBlock"
                                           Text="•"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="LiveStatusTextBlock"
                                           Text="Neutral..."
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                    </Grid>

                    <ListBox x:Name="MatchEventsListBox"
                             Grid.Row="1"
                             Background="{DynamicResource AppPanelBackground}"
                             BorderThickness="0"
                             Padding="6"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MatchFeedItem}">
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        CornerRadius="9"
                                        Background="{Binding RowBackground}"
                                        BorderBrush="{Binding RowBorderBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="30"
                                                Height="30"
                                                CornerRadius="15"
                                                Background="{Binding IconBackground}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe UI Emoji"
                                                       FontSize="17"
                                                       Foreground="{Binding IconForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding MinuteText}"
                                                           Foreground="{Binding MinuteForeground}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Margin="0,0,8,0" />
                                                <Border Background="{Binding LabelBackground}"
                                                        CornerRadius="7"
                                                        Padding="5,1">
                                                    <TextBlock Text="{Binding EventLabel}"
                                                               Foreground="{Binding LabelForeground}"
                                                               FontSize="10"
                                                               FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{Binding TitleForeground}"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />

                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{Binding DescriptionForeground}"
                                                       FontSize="11"
                                                       LineHeight="16"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Width="22"
                                                Height="22"
                                                CornerRadius="11"
                                                Background="{Binding TraitBadgeBackground}"
                                                BorderBrush="{Binding TraitBadgeBorderBrush}"
                                                BorderThickness="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                ToolTip="{Binding TriggeredTraitDescription}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasTriggeredTrait}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding TriggeredTraitIcon}"
                                                       FontFamily="Segoe UI Emoji"
                                                       FontSize="11"
                                                       FontWeight="Black"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="FullMatchLayoutGrid"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#08783F"
                    CornerRadius="14"
                    Padding="10">
                <Grid ClipToBounds="True">
                    <Rectangle Fill="#0BA956"
                               RadiusX="12"
                               RadiusY="12" />
                    <Line X1="0" Y1="0" X2="0" Y2="900"
                          Stroke="#B6F2CC"
                          StrokeThickness="2"
                          Opacity="0.65"
                          HorizontalAlignment="Center" />
                    <Ellipse Width="150"
                             Height="150"
                             Stroke="#B6F2CC"
                             StrokeThickness="2"
                             Opacity="0.55"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <Rectangle Width="120"
                               Height="260"
                               Stroke="#B6F2CC"
                               StrokeThickness="2"
                               Opacity="0.45"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0,0,0,0" />
                    <Rectangle Width="120"
                               Height="260"
                               Stroke="#B6F2CC"
                               StrokeThickness="2"
                               Opacity="0.45"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,0,0" />

                    <Grid IsHitTestVisible="False"
                          Panel.ZIndex="4"
                          Margin="18,12,18,0"
                          VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AttackPitchStatusBadge"
                                Width="32"
                                Height="28"
                                CornerRadius="14"
                                Background="#CCB42318"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Right"
                                Visibility="Collapsed">
                            <TextBlock x:Name="AttackPitchStatusIconTextBlock"
                                       Text="⚔"
                                       FontFamily="Segoe UI Symbol"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Border x:Name="DefensePitchStatusBadge"
                                Width="32"
                                Height="28"
                                CornerRadius="14"
                                Background="#CC174A8B"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                Visibility="Collapsed">
                            <TextBlock x:Name="DefensePitchStatusIconTextBlock"
                                       Text="🛡"
                                       FontFamily="Segoe UI Symbol"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <ItemsControl x:Name="PitchPlayersItemsControl"
                                  ItemsSource="{Binding}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  SizeChanged="LivePitchCanvas_SizeChanged">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <StaticResource ResourceKey="PitchPlayerIconTemplate" />
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Orientation="Horizontal"
                                Margin="0,8,8,0"
                                Background="#66102033"
                                Opacity="0.82">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="32" />
                                <Setter Property="Height" Value="28" />
                                <Setter Property="Margin" Value="2" />
                                <Setter Property="Background" Value="#AA1A2D44" />
                                <Setter Property="Foreground" Value="{DynamicResource AppInverseTextBrush}" />
                                <Setter Property="BorderBrush" Value="#66FFFFFF" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="FontFamily" Value="Segoe UI Symbol" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </StackPanel.Resources>
                        <Button x:Name="PauseResumeButton"
                                Content="&#x23F8;"
                                Click="PauseResumeButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12" />
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="DecreaseSpeedButton"
                                Content="&#x23EA;"
                                Click="DecreaseSpeedButton_Click" />
                        <Border Width="54"
                                Height="32"
                                CornerRadius="10"
                                Background="{DynamicResource AppHighlightBrush}"
                                Margin="3"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="SpeedLevelTextBlock"
                                       Text="1x"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Button x:Name="IncreaseSpeedButton"
                                Content="&#x23E9;"
                                Click="IncreaseSpeedButton_Click" />
                        <Button x:Name="ContinueButton"
                                Style="{StaticResource PrimaryTextButton}"
                                Content="Continue"
                                Width="84"
                                Height="28"
                                Margin="2"
                                Visibility="Collapsed"
                                IsEnabled="False"
                                Click="ContinueButton_Click" />
                    </StackPanel>

                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource AppCardBackground}"
                        CornerRadius="12"
                        Padding="10"
                        Margin="0,0,8,0">
                    <Grid>
                        <TextBlock x:Name="SelectedPlayerPlaceholderTextBlock"
                                   Text="Select a player on the pitch to view details."
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />

                        <StackPanel x:Name="SelectedPlayerStatsPanel"
                                    Visibility="Collapsed">
                            <Grid Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding FlagImagePath}"
                                           ToolTip="{Binding NationalityName}"
                                           Width="18"
                                           Height="12"
                                           Stretch="UniformToFill"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                    <TextBlock x:Name="SelectedPlayerNameTextBlock"
                                               Grid.Column="1"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <ItemsControl x:Name="SelectedPlayerTraitItemsControl"
                                                  ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                                  Margin="0,0,4,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <ItemsControl x:Name="SelectedPlayerCardStatusItemsControl"
                                                  ItemTemplate="{StaticResource CardStatusBadgeTemplate}"
                                                  Margin="0,0,4,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <Border x:Name="SelectedPlayerFormBadgeBorder"
                                            CornerRadius="10"
                                            Padding="8,3"
                                            Background="{DynamicResource AppSecondaryCardBackground}"
                                            VerticalAlignment="Center">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#203B2D"
                                                              BlurRadius="6"
                                                              ShadowDepth="1"
                                                              Opacity="0.18" />
                                        </Border.Effect>
                                        <TextBlock x:Name="SelectedPlayerFormBadgeTextBlock"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="SelectedPlayerMetaTextBlock"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,1,0,6" />

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat4Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat4Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat5Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat5Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerLeftStat6Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerLeftStat6Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat1Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat1Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat2Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat2Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat3Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat3Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat4Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat4Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat5Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat5Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedPlayerRightStat6Label" Foreground="{DynamicResource AppMutedTextBrush}" FontSize="9" FontWeight="SemiBold" />
                                        <TextBlock x:Name="SelectedPlayerRightStat6Value" Grid.Column="1" Foreground="{DynamicResource AppTextBrush}" FontSize="10.5" FontWeight="Bold" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="{DynamicResource AppCardBackground}"
                        CornerRadius="12"
                        Padding="8"
                        Margin="0,0,8,0">
                    <Grid>
                        <Grid x:Name="PausedActionPanel"
                              Margin="0">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="82" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Formation"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <ComboBox x:Name="ActionFormationComboBox"
                                              Grid.Column="1"
                                              MinHeight="24"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Name"
                                              TextSearch.TextPath="Name"
                                              SelectionChanged="FormationComboBox_SelectionChanged">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Margin="6,4,0,2" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                </Grid>

                                <controls:TacticalSettingsPanel x:Name="ActionTacticalSettingsPanel"
                                                                IsCompact="True"
                                                                PanelMaxHeight="220" />

                                <TextBlock x:Name="PausedActionStatusTextBlock"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           FontSize="8.5"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="PausedSubstitutionPanelBorder"
                        Grid.Column="2"
                        Background="{DynamicResource AppCardBackground}"
                        BorderBrush="Transparent"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4">
                            <TextBlock.Inlines>
                                <Run Text="Substitutes" />
                                <Run Text="   " />
                                <Run x:Name="SubsLeftTextBlock"
                                     Foreground="{DynamicResource AppMutedTextBrush}"
                                     FontSize="11"
                                     FontWeight="SemiBold" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <ListBox x:Name="PausedBenchListBox"
                                 Grid.Row="1"
                                 SelectionChanged="PausedBenchListBox_SelectionChanged"
                                 ItemTemplate="{StaticResource SubstitutionPlayerTemplate}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,8,0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <TextBlock x:Name="NoAvailableSubstituteTextBlock"
                                   Grid.Row="1"
                                   Text="No available substitute for this position"
                                   Foreground="{DynamicResource FeedAttackLabelForeground}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="SubstitutionOverlay"
                  Grid.RowSpan="2"
                  Background="#A6112233"
                  Visibility="Collapsed">
                <Border Width="760"
                        Background="{DynamicResource AppSecondaryCardBackground}"
                        CornerRadius="14"
                        Padding="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Make Substitution"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="24"
                                   FontWeight="Bold" />

                        <TextBlock x:Name="SubstitutionOverlayStatusTextBlock"
                                   Grid.Row="1"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,18" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="Current Starters"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />
                                <ListBox x:Name="LiveStarterListBox"
                                         Height="290"
                                         SelectionChanged="LiveStarterListBox_SelectionChanged"
                                         ItemTemplate="{StaticResource SubstitutionPlayerTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,6" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="Available Substitutes"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10" />
                                <ListBox x:Name="LiveBenchListBox"
                                         Height="290"
                                         SelectionChanged="LiveBenchListBox_SelectionChanged"
                                         ItemTemplate="{StaticResource SubstitutionPlayerTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,6" />
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,18,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Width="110"
                                    Height="36"
                                    Margin="0,0,10,0"
                                    Click="CancelSubstitutionButton_Click" />
                            <Button x:Name="ConfirmSubstitutionButton"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Content="Confirm Substitution"
                                    Width="170"
                                    Height="36"
                                    IsEnabled="False"
                                    Click="ConfirmSubstitutionButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TacticalAdjustmentOverlay"
                  Grid.RowSpan="2"
                  Background="#A6112233"
                  Visibility="Collapsed">
                <Border Width="560"
                        Background="{DynamicResource AppSecondaryCardBackground}"
                        CornerRadius="14"
                        Padding="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Tactical Adjustment"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="TacticalOverlayStatusTextBlock"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontSize="10"
                                   Margin="0,4,0,8" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Formation"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <ComboBox x:Name="TacticalFormationComboBox"
                                      Grid.Column="1"
                                      MinHeight="28"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Name"
                                      TextSearch.TextPath="Name"
                                      SelectionChanged="FormationComboBox_SelectionChanged">
                                <ComboBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Margin="6,4,0,2" />
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ComboBox.GroupStyle>
                            </ComboBox>
                        </Grid>

                        <controls:TacticalSettingsPanel x:Name="TacticalSettingsPanel"
                                                        IsCompact="True"
                                                        PanelMaxHeight="320" />

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0">
                            <Button Content="Cancel"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Width="92"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    Click="CancelTacticalAdjustmentButton_Click" />
                            <Button Content="Apply Tactics"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Width="120"
                                    Height="30"
                                    Click="ConfirmTacticalAdjustmentButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
