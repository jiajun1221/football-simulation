<UserControl x:Class="FootballSimulation.Wpf.Views.MatchLiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FootballSimulation.Wpf.Models">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F1B2D"
                CornerRadius="18"
                Padding="22"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock x:Name="PhaseTextBlock"
                           Foreground="#AFC1D8"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />

                <Grid Margin="0,14,0,0"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ScoreboardScaleTransform" ScaleX="1" ScaleY="1" />
                    </Grid.RenderTransform>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="HomeScorePanel"
                            Grid.Column="0"
                            Background="#172A45"
                            CornerRadius="14"
                            Padding="18">
                        <StackPanel>
                            <TextBlock x:Name="HomeTeamNameTextBlock"
                                       Foreground="#DCE8F7"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="HomeScoreTextBlock"
                                       Foreground="White"
                                       FontSize="46"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="-"
                               Foreground="#E2EAF5"
                               FontSize="42"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="20,0" />

                    <Border x:Name="AwayScorePanel"
                            Grid.Column="2"
                            Background="#172A45"
                            CornerRadius="14"
                            Padding="18">
                        <StackPanel>
                            <TextBlock x:Name="AwayTeamNameTextBlock"
                                       Foreground="#DCE8F7"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="AwayScoreTextBlock"
                                       Foreground="White"
                                       FontSize="46"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="18"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Live Match Feed"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#14233A"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Speed"
                                   Foreground="#607187"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="SpeedComboBox"
                                  Width="150"
                                  Height="32"
                                  Margin="0,0,10,0"
                                  SelectionChanged="SpeedComboBox_SelectionChanged" />

                        <Button x:Name="SkipButton"
                                Content="Skip"
                                Width="82"
                                Height="32"
                                Margin="0,0,10,0"
                                Click="SkipButton_Click" />

                        <Button x:Name="ContinueButton"
                                Content="Continue"
                                Width="128"
                                Height="32"
                                Visibility="Collapsed"
                                IsEnabled="False"
                                Click="ContinueButton_Click" />
                    </StackPanel>
                </Grid>

                <ListBox x:Name="MatchEventsListBox"
                         Grid.Row="1"
                         Background="#F3F6FA"
                         BorderThickness="0"
                         Padding="8"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:MatchFeedItem}">
                            <Border Margin="0,0,0,10"
                                    Padding="16"
                                    CornerRadius="14"
                                    Background="{Binding RowBackground}"
                                    BorderBrush="{Binding RowBorderBrush}"
                                    BorderThickness="1.5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="46"
                                            Height="46"
                                            CornerRadius="23"
                                            Background="{Binding IconBackground}"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="Segoe UI Emoji"
                                                   FontSize="25"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#E9EEF5"
                                                    CornerRadius="10"
                                                    Padding="8,4"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding MinuteText}"
                                                           Foreground="#14233A"
                                                           FontSize="12"
                                                           FontWeight="Bold" />
                                            </Border>

                                            <Border Background="{Binding LabelBackground}"
                                                    CornerRadius="10"
                                                    Padding="9,4">
                                                <TextBlock Text="{Binding EventLabel}"
                                                           Foreground="{Binding LabelForeground}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding TeamName}"
                                                   Foreground="#607187"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0" />

                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#102033"
                                                   FontSize="17"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />

                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="#34465C"
                                                   FontSize="14"
                                                   LineHeight="20"
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,0" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="#102033"
                                            CornerRadius="12"
                                            Padding="12,7"
                                            VerticalAlignment="Top"
                                            Margin="14,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGoal}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ScoreText}"
                                                   Foreground="White"
                                                   FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
