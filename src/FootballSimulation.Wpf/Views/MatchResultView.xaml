<UserControl x:Class="FootballSimulation.Wpf.Views.MatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <DataTemplate x:Key="PlayerPerformanceTemplate">
            <Border Background="{Binding RowBackground}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="10"
                    Padding="9"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding MotmIcon}"
                                       Foreground="#E3A500"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,5,0"
                                       Visibility="{Binding MotmVisibility}" />
                            <TextBlock Text="{Binding PlayerName}"
                                       Foreground="#102033"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="#607187"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#607187"
                                       FontSize="10" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Border Background="#EAF8EF"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding GoalVisibility}">
                                <TextBlock Text="{Binding GoalText}"
                                           Foreground="#1D5F34"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="#E8F1FF"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding AssistVisibility}">
                                <TextBlock Text="{Binding AssistText}"
                                           Foreground="#1E528F"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="#FFE36B"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding YellowVisibility}">
                                <TextBlock Text="{Binding YellowText}"
                                           Foreground="#5F4500"
                                           FontSize="9"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="#D94343"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Visibility="{Binding RedVisibility}">
                                <TextBlock Text="{Binding RedText}"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#102033"
                            CornerRadius="10"
                            Padding="9,5"
                            Margin="10,0,0,0"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding RatingText}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ScorerTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="#CFE3FF"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Margin="0,2"
                       TextWrapping="Wrap" />
        </DataTemplate>

        <DataTemplate x:Key="StatComparisonTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding HomeValue}"
                           Foreground="#102033"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Right" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Label}"
                           Foreground="#607187"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding AwayValue}"
                           Foreground="#102033"
                           FontSize="16"
                           FontWeight="Bold" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#102033"
                CornerRadius="24"
                Padding="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="FULL TIME"
                           Foreground="#90A4BE"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="HomeTeamTextBlock"
                               Foreground="#FFFFFF"
                               FontSize="25"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Right" />
                    <ItemsControl x:Name="HomeScorersItemsControl"
                                  ItemTemplate="{StaticResource ScorerTemplate}"
                                  HorizontalAlignment="Right"
                                  Margin="0,10,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="38,0"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="ScoreTextBlock"
                               Foreground="White"
                               FontSize="66"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="AwayTeamTextBlock"
                               Foreground="#FFFFFF"
                               FontSize="25"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="AwayScorersItemsControl"
                                  ItemTemplate="{StaticResource ScorerTemplate}"
                                  Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="HomePlayersTitleTextBlock"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,12" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HomePlayersItemsControl"
                                      ItemTemplate="{StaticResource PlayerPerformanceTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Match Stats"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#102033"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18" />
                    <ItemsControl x:Name="StatsComparisonItemsControl"
                                  Grid.Row="1"
                                  ItemTemplate="{StaticResource StatComparisonTemplate}" />
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AwayPlayersTitleTextBlock"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,12" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AwayPlayersItemsControl"
                                      ItemTemplate="{StaticResource PlayerPerformanceTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="4"
                Content="Next"
                Width="180"
                Height="46"
                HorizontalAlignment="Right"
                Background="#102033"
                Foreground="White"
                FontWeight="Bold"
                BorderThickness="0"
                Click="NextButton_Click" />
    </Grid>
</UserControl>
