<UserControl x:Class="FootballSimulation.Wpf.Views.MatchResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="2,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CardStatusBadgeTemplate">
            <Border MinWidth="14"
                    Height="14"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Text}"
                           Foreground="{Binding Foreground}"
                           FontSize="7.5"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16"
                                      ShadowDepth="2"
                                      Opacity="0.10"
                                      Color="#102033" />
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PlayerPerformanceTemplate">
            <Border Background="{Binding RowBackground}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="10"
                    Padding="9"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MotmIcon}"
                                       Foreground="#E3A500"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,5,0"
                                       Visibility="{Binding MotmVisibility}" />
                            <Image Source="{Binding FlagImagePath}"
                                   ToolTip="{Binding NationalityName}"
                                   Width="18"
                                   Height="12"
                                   Stretch="UniformToFill"
                                   Margin="0,0,5,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PlayerName}"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <Border Background="{Binding FormBadgeBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="7,0,3,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding FormBadgeText}"
                                           Foreground="{Binding FormBadgeForeground}"
                                           FontSize="9"
                                           FontWeight="Bold" />
                            </Border>
                            <ItemsControl ItemsSource="{Binding TraitBadges}"
                                          ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                          VerticalAlignment="Center">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding CardStatusBadges}"
                                          ItemTemplate="{StaticResource CardStatusBadgeTemplate}"
                                          VerticalAlignment="Center">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CardStatusBadges.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="10"
                                       FontWeight="Black"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="10"
                                       FontWeight="Black"
                                       Margin="0,0,8,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       FontSize="10"
                                       Margin="0,0,8,0" />
                        </StackPanel>

                        <WrapPanel Margin="0,5,0,0">
                            <Border Background="{DynamicResource FeedDefensiveIconBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding GoalVisibility}">
                                <TextBlock Text="{Binding GoalText}"
                                           Foreground="{DynamicResource FeedDefensiveIconForeground}"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="{DynamicResource FeedChanceIconBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding AssistVisibility}">
                                <TextBlock Text="{Binding AssistText}"
                                           Foreground="{DynamicResource FeedChanceIconForeground}"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="{DynamicResource FeedDefensiveIconBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding DefensiveVisibility}">
                                <TextBlock Text="{Binding DefensiveText}"
                                           Foreground="{DynamicResource FeedDefensiveIconForeground}"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="{DynamicResource FeedDefensiveIconBackground}"
                                    CornerRadius="7"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding SaveVisibility}">
                                <TextBlock Text="{Binding SaveText}"
                                           Foreground="{DynamicResource FeedDefensiveIconForeground}"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="{DynamicResource FeedFoulIconBackground}"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Margin="0,0,5,0"
                                    Visibility="{Binding YellowVisibility}">
                                <TextBlock Text="{Binding YellowText}"
                                           Foreground="{DynamicResource FeedFoulIconForeground}"
                                           FontSize="9"
                                           FontWeight="Bold" />
                            </Border>

                            <Border Background="#D94343"
                                    CornerRadius="3"
                                    Padding="5,1"
                                    Visibility="{Binding RedVisibility}">
                                <TextBlock Text="{Binding RedText}"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Bold" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{Binding RatingBackground}"
                            CornerRadius="10"
                            Padding="9,5"
                            Margin="10,0,0,0"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding RatingText}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ScorerTemplate">
            <Grid Margin="0,0,0,6"
                  ToolTip="{Binding TooltipText}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="{Binding BadgeBackground}"
                        CornerRadius="8"
                        Padding="5,1"
                        Margin="0,0,6,0"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding BadgeText}"
                               Foreground="{Binding BadgeForeground}"
                               FontFamily="Segoe UI Emoji"
                               FontSize="9"
                               FontWeight="Black" />
                </Border>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding SummaryText}"
                               Foreground="#E6EEF8"
                               FontSize="11"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding MinuteText}"
                               Foreground="#90A4BE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Visibility="{Binding MinuteVisibility}" />
                    <TextBlock Text="{Binding AchievementText}"
                               Foreground="#F7C948"
                               FontSize="9"
                               FontWeight="Black"
                               TextWrapping="Wrap"
                               Visibility="{Binding AchievementVisibility}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ScorerPanelTemplate">
            <Border Background="#1A2740"
                    BorderBrush="#2D3B55"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10"
                    MaxHeight="126">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding Title}"
                               Foreground="#E6EEF8"
                               FontSize="11"
                           FontWeight="Black"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,7" />
                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="92"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Scorers}"
                                      ItemTemplate="{StaticResource ScorerTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StatComparisonTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding HomeValue}"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Right" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Label}"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding AwayValue}"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="16"
                           FontWeight="Bold" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24"
          Background="{DynamicResource AppPageBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppPrimaryBrush}"
                CornerRadius="24"
                Padding="28"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ResultHeaderTextBlock"
                           Grid.Row="0"
                           Grid.Column="3"
                           Text="FULL TIME"
                           Foreground="#90A4BE"
                           FontSize="13"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <ContentControl x:Name="HomeScorersContentControl"
                                Grid.Row="1"
                                Grid.Column="0"
                                ContentTemplate="{StaticResource ScorerPanelTemplate}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0" />

                <Border x:Name="HomeTeamLogoBorder"
                        Grid.Row="1"
                        Grid.Column="1"
                        Width="72"
                        Height="72"
                        CornerRadius="36"
                        Background="{DynamicResource AppPanelBackground}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Image x:Name="HomeTeamLogoImage"
                           Width="54"
                           Height="54"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <TextBlock x:Name="HomeTeamTextBlock"
                           Grid.Row="1"
                           Grid.Column="2"
                           Foreground="#FFFFFF"
                           FontSize="25"
                           FontWeight="Bold"
                           TextWrapping="NoWrap"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Margin="0,0,18,0" />

                <TextBlock x:Name="ScoreTextBlock"
                           Grid.Row="1"
                           Grid.Column="3"
                           Foreground="White"
                           FontSize="66"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />

                <TextBlock x:Name="AwayTeamTextBlock"
                           Grid.Row="1"
                           Grid.Column="4"
                           Foreground="#FFFFFF"
                           FontSize="25"
                           FontWeight="Bold"
                           TextWrapping="NoWrap"
                           TextAlignment="Left"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0" />

                <Border x:Name="AwayTeamLogoBorder"
                        Grid.Row="1"
                        Grid.Column="5"
                        Width="72"
                        Height="72"
                        CornerRadius="36"
                        Background="{DynamicResource AppPanelBackground}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Image x:Name="AwayTeamLogoImage"
                           Width="54"
                           Height="54"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <ContentControl x:Name="AwayScorersContentControl"
                                Grid.Row="1"
                                Grid.Column="6"
                                ContentTemplate="{StaticResource ScorerPanelTemplate}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="HomePlayersTitleTextBlock"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,0,0,12" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="HomePlayersItemsControl"
                                      ItemTemplate="{StaticResource PlayerPerformanceTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Match Stats"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18" />
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="StatsComparisonItemsControl"
                                      ItemTemplate="{StaticResource StatComparisonTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SummaryCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AwayPlayersTitleTextBlock"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}"
                               Margin="0,0,0,12" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AwayPlayersItemsControl"
                                      ItemTemplate="{StaticResource PlayerPerformanceTemplate}" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="4"
                Style="{StaticResource PrimaryTextButton}"
                Content="Next"
                Width="180"
                Height="46"
                HorizontalAlignment="Right"
                Background="{DynamicResource AppPrimaryBrush}"
                Foreground="White"
                FontWeight="Bold"
                BorderThickness="0"
                Click="NextButton_Click" />
    </Grid>
</UserControl>
