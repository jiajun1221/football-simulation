<UserControl x:Class="FootballSimulation.Wpf.Views.MyTeamResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="ResultsCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="158" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#0F172A" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="13"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackButtonBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CenteredText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>

        <Style x:Key="ResultsGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowHeight" Value="62" />
            <Setter Property="ColumnHeaderHeight" Value="40" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource TableHeaderBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TableHeaderForeground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResultRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <DataTemplate x:Key="ResultBadgeTemplate">
            <Border Background="{Binding ResultBrush}"
                    CornerRadius="12"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <TextBlock Text="{Binding ResultText}"
                           Foreground="#FFFFFF"
                           FontWeight="Black"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OpponentTemplate">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Image Source="{Binding OpponentLogoPath}"
                       Width="30"
                       Height="30"
                       Stretch="Uniform"
                       Margin="0,0,10,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding OpponentName}"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding HomeAwayText}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PlayerOfTheMatchTemplate">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Image Source="{Binding PlayerOfTheMatchLogoPath}"
                       Width="24"
                       Height="24"
                       Stretch="Uniform"
                       Margin="0,0,8,0" />
                <TextBlock Text="{Binding PlayerOfTheMatchName}"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           Text="Match History"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="28"
                           FontWeight="Black" />
                <TextBlock x:Name="SubtitleTextBlock"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Content="Back to Dashboard"
                    Style="{StaticResource BackButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="BackButton_Click" />
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource ResultsCard}"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="RecordTextBlock"
                           Foreground="{DynamicResource AppTextBrush}"
                           FontSize="18"
                           FontWeight="Black"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="GoalsTextBlock"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ResultsCard}">
            <Grid>
                <TextBlock x:Name="EmptyTextBlock"
                           Text="No completed matches yet."
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <DataGrid x:Name="ResultsDataGrid"
                          Style="{StaticResource ResultsGridStyle}"
                          RowStyle="{StaticResource ResultRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Round" Binding="{Binding RoundText}" Width="130" ElementStyle="{StaticResource CenteredText}" />
                        <DataGridTextColumn Header="Competition" Binding="{Binding CompetitionText}" Width="150" ElementStyle="{StaticResource CenteredText}" />
                        <DataGridTemplateColumn Header="Result" Width="70" CellTemplate="{StaticResource ResultBadgeTemplate}" />
                        <DataGridTextColumn Header="Score" Binding="{Binding ScoreText}" Width="110" ElementStyle="{StaticResource CenteredText}" />
                        <DataGridTemplateColumn Header="Opponent" Width="*" CellTemplate="{StaticResource OpponentTemplate}" />
                        <DataGridTextColumn Header="Venue" Binding="{Binding VenueText}" Width="150" ElementStyle="{StaticResource CenteredText}" />
                        <DataGridTemplateColumn Header="Player of the Match" Width="210" CellTemplate="{StaticResource PlayerOfTheMatchTemplate}" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding NotesText}" Width="190" ElementStyle="{StaticResource CenteredText}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
