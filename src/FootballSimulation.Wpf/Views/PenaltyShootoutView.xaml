<UserControl x:Class="FootballSimulation.Wpf.Views.PenaltyShootoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="ShootoutPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <DataTemplate x:Key="PenaltyIndicatorTemplate">
            <Ellipse Width="22"
                     Height="22"
                     Fill="{Binding Fill}"
                     Stroke="{Binding Stroke}"
                     StrokeThickness="2"
                     Margin="4"
                     ToolTip="{Binding Tooltip}" />
        </DataTemplate>

        <DataTemplate x:Key="OrderSlotTemplate">
            <Border Width="42"
                    MinHeight="42"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="4"
                    Margin="3">
                <StackPanel>
                    <TextBlock Text="{Binding Number}"
                               Foreground="{Binding NumberForeground}"
                               FontSize="13"
                               FontWeight="Black"
                               TextAlignment="Center" />
                    <TextBlock Text="{Binding PlayerShortName}"
                               Foreground="{Binding PlayerForeground}"
                               FontSize="7.5"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlayerCardTemplate">
            <Border Width="220"
                    Height="72"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="13"
                    Padding="9"
                    Margin="0,0,0,8"
                    ToolTip="{Binding Name}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{Binding NameForeground}"
                                   FontSize="12"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Border Background="{Binding PositionBackground}"
                                    CornerRadius="7"
                                    Padding="6,2">
                                <TextBlock Text="{Binding Position}"
                                           Foreground="White"
                                           FontSize="9"
                                           FontWeight="Black" />
                            </Border>
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding MetaForeground}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Margin="8,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="{Binding PenaltyBackground}"
                            CornerRadius="10"
                            Padding="8,4">
                        <TextBlock Text="{Binding PenaltyText}"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Black" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BreakdownTemplate">
            <TextBlock Text="{Binding Text}"
                       Foreground="{Binding Foreground}"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,2"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <DataTemplate x:Key="FeedItemTemplate">
            <Border Margin="0,0,0,8"
                    Padding="10"
                    CornerRadius="12"
                    Background="{Binding RowBackground}"
                    BorderBrush="{Binding RowBorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="30"
                            Height="30"
                            CornerRadius="15"
                            Background="{Binding IconBackground}"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding Icon}"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="17"
                                   Foreground="{Binding IconForeground}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding MinuteText}"
                                       Foreground="{Binding MinuteForeground}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Margin="0,0,8,0" />
                            <Border Background="{Binding LabelBackground}"
                                    CornerRadius="7"
                                    Padding="6,1">
                                <TextBlock Text="{Binding EventLabel}"
                                           Foreground="{Binding LabelForeground}"
                                           FontSize="10"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding Title}"
                                   Foreground="{Binding TitleForeground}"
                                   FontSize="13"
                                   FontWeight="Black"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />

                        <TextBlock Text="{Binding Description}"
                                   Foreground="{Binding DescriptionForeground}"
                                   FontSize="11.5"
                                   LineHeight="16"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border x:Name="HomeTeamPanelBorder"
                    Grid.Column="0"
                    Style="{StaticResource ShootoutPanelStyle}"
                    BorderBrush="#4F6CF7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="HomeLogoImage"
                               Width="58"
                               Height="58"
                               Stretch="Uniform"
                               Margin="0,0,0,8" />
                        <TextBlock x:Name="HomeTeamTextBlock"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="18"
                                   FontWeight="Black"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl x:Name="HomeIndicatorsItemsControl"
                                  Grid.Row="1"
                                  ItemTemplate="{StaticResource PenaltyIndicatorTemplate}"
                                  HorizontalAlignment="Center"
                                  Margin="0,16,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl x:Name="HomeOrderItemsControl"
                                  Grid.Row="2"
                                  ItemTemplate="{StaticResource OrderSlotTemplate}"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Button x:Name="HomeAutoPickButton"
                            Grid.Row="3"
                            Content="Auto Pick Best 5"
                            Style="{StaticResource PrimaryTextButton}"
                            Height="30"
                            FontSize="11"
                            FontWeight="Bold"
                            Margin="20,0,20,10"
                            Click="AutoPickBestButton_Click" />

                    <ListBox x:Name="HomePlayersListBox"
                             Grid.Row="4"
                             SelectionMode="Multiple"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource PlayerCardTemplate}"
                             SelectionChanged="PlayerSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <TextBlock x:Name="HomeSelectionHintTextBlock"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="18,0"
                    Background="#05B967"
                    BorderBrush="#B7FFE0"
                    BorderThickness="2"
                    CornerRadius="24"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="CenterHeaderPanel"
                                HorizontalAlignment="Center"
                                MinHeight="54"
                                MaxHeight="60">
                        <TextBlock x:Name="ExtraTimeScoreTextBlock"
                                   Text="Penalty Shootout"
                                   Foreground="#072817"
                                   FontSize="16"
                                   FontWeight="Black"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="FixtureTextBlock"
                                   Foreground="#E8FFF3"
                                   FontSize="17"
                                   FontWeight="Black"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0" />
                        <TextBlock x:Name="RoundTextBlock"
                                   Text="Select Penalty Takers"
                                   Visibility="Collapsed"
                                   Foreground="#072817"
                                   FontSize="17"
                                   FontWeight="Black"
                                   TextAlignment="Center" />
                        <TextBlock x:Name="CurrentResultTextBlock"
                                   Text="READY?"
                                   Visibility="Collapsed"
                                   Foreground="#FFFFFF"
                                   FontSize="32"
                                   FontWeight="Black"
                                   TextAlignment="Center"
                                   Margin="0,6,0,0" />
                        <TextBlock x:Name="KickDuelTextBlock"
                                   Text="Choose 5 takers for your team."
                                   Visibility="Collapsed"
                                   Foreground="#E8FFF3"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Viewbox x:Name="PitchViewbox"
                             Grid.Row="1"
                             Stretch="Uniform">
                    <Canvas Width="650"
                            Height="430"
                            Margin="0,8">
                        <Rectangle Width="310"
                                   Height="122"
                                   Stroke="#FFFFFF"
                                   StrokeThickness="6"
                                   RadiusX="14"
                                   RadiusY="14"
                                   Canvas.Left="170"
                                   Canvas.Top="34" />
                        <Line X1="0"
                              Y1="166"
                              X2="650"
                              Y2="166"
                              Stroke="#FFFFFF"
                              StrokeThickness="5" />
                        <Polyline Points="140,166 92,280 558,280 510,166"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="5"
                                  Fill="Transparent" />
                        <TextBlock x:Name="BallMarker"
                                   Text="⚽"
                                   FontSize="34"
                                   Canvas.Left="308"
                                   Canvas.Top="286"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <Border x:Name="GoalkeeperMarker"
                                Width="60"
                                Height="60"
                                Background="#EF3333"
                                BorderBrush="#FFFFFF"
                                BorderThickness="2"
                                CornerRadius="30"
                                Canvas.Left="295"
                                Canvas.Top="108">
                            <TextBlock x:Name="GoalkeeperTextBlock"
                                       Text="GK"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="TakerMarker"
                                Width="60"
                                Height="60"
                                Background="#4F6CF7"
                                BorderBrush="#FFFFFF"
                                BorderThickness="2"
                                CornerRadius="30"
                                Canvas.Left="295"
                                Canvas.Top="338">
                            <TextBlock x:Name="TakerNumberTextBlock"
                                       Text="10"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Black"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Canvas>
                    </Viewbox>

                    <Border x:Name="BottomFeedPanel"
                            Grid.Row="2"
                            Background="#092E1A"
                            CornerRadius="16"
                            Padding="14"
                            MinHeight="148">
                        <Grid>
                            <ListBox x:Name="LiveFeedListBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Height="126"
                                     ItemTemplate="{StaticResource FeedItemTemplate}"
                                     Visibility="Collapsed"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <Grid x:Name="ReadyPanel">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="StatusTextBlock"
                                           Text="Select 5 penalty takers."
                                           Foreground="#E8FFF3"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ScorelineTextBlock"
                                           Text="Pens: 0 - 0"
                                           Foreground="#A7F35D"
                                           FontSize="16"
                                           FontWeight="Black"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="PrimaryActionButton"
                                    Grid.Column="1"
                                    Content="Ready"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Width="180"
                                    Height="44"
                                    Margin="16,0,0,0"
                                    FontWeight="Bold"
                                    Click="PrimaryActionButton_Click" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="FinalResultPanel"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            Background="#0B2D1C"
                            CornerRadius="22"
                            Padding="24"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Image x:Name="FinalWinnerLogoImage"
                                   Width="96"
                                   Height="96"
                                   Stretch="Uniform"
                                   Margin="0,0,0,14" />
                            <TextBlock x:Name="FinalWinnerTextBlock"
                                       Foreground="#FFFFFF"
                                       FontSize="30"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="FinalPenaltyScoreTextBlock"
                                       Foreground="#A7F35D"
                                       FontSize="34"
                                       FontWeight="Black"
                                       TextAlignment="Center"
                                       Margin="0,10,0,20" />
                            <Button x:Name="FinalContinueButton"
                                    Content="Continue"
                                    Style="{StaticResource PrimaryTextButton}"
                                    Width="190"
                                    Height="44"
                                    FontWeight="Bold"
                                    Click="PrimaryActionButton_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="AwayTeamPanelBorder"
                    Grid.Column="2"
                    Style="{StaticResource ShootoutPanelStyle}"
                    BorderBrush="#FF333A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="AwayLogoImage"
                               Width="58"
                               Height="58"
                               Stretch="Uniform"
                               Margin="0,0,0,8" />
                        <TextBlock x:Name="AwayTeamTextBlock"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="18"
                                   FontWeight="Black"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl x:Name="AwayIndicatorsItemsControl"
                                  Grid.Row="1"
                                  ItemTemplate="{StaticResource PenaltyIndicatorTemplate}"
                                  HorizontalAlignment="Center"
                                  Margin="0,16,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <ItemsControl x:Name="AwayOrderItemsControl"
                                  Grid.Row="2"
                                  ItemTemplate="{StaticResource OrderSlotTemplate}"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Button x:Name="AwayAutoPickButton"
                            Grid.Row="3"
                            Content="Auto Pick Best 5"
                            Style="{StaticResource PrimaryTextButton}"
                            Height="30"
                            FontSize="11"
                            FontWeight="Bold"
                            Margin="20,0,20,10"
                            Click="AutoPickBestButton_Click" />

                    <ListBox x:Name="AwayPlayersListBox"
                             Grid.Row="4"
                             SelectionMode="Multiple"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource PlayerCardTemplate}"
                             SelectionChanged="PlayerSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <TextBlock x:Name="AwaySelectionHintTextBlock"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="ResultBreakdownBorder"
                Grid.Row="1"
                Background="{DynamicResource AppCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18"
                Margin="0,18,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="HomeBreakdownTitleTextBlock"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontSize="14"
                               FontWeight="Black"
                               Margin="0,0,0,6" />
                    <ItemsControl x:Name="HomeBreakdownItemsControl"
                                  ItemTemplate="{StaticResource BreakdownTemplate}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="AwayBreakdownTitleTextBlock"
                               Foreground="{DynamicResource AppTextBrush}"
                               FontSize="14"
                               FontWeight="Black"
                               Margin="0,0,0,6" />
                    <ItemsControl x:Name="AwayBreakdownItemsControl"
                                  ItemTemplate="{StaticResource BreakdownTemplate}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
