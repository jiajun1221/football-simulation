<UserControl x:Class="FootballSimulation.Wpf.Views.PreMatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <Style x:Key="PitchPlayerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SavedFormationLoadButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F6" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D5DEE8" />
                                <Setter Property="Foreground" Value="#7A8798" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TraitIconBadgeTemplate">
            <Border Width="14"
                    Height="14"
                    Background="{Binding Background}"
                    CornerRadius="7"
                    Margin="1,0,0,0"
                    ToolTip="{Binding TooltipText}">
                <TextBlock Text="{Binding Icon}"
                           Foreground="{Binding Foreground}"
                           FontFamily="{Binding FontFamily}"
                           FontSize="8"
                           FontWeight="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PitchPlayerCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding MutedForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding OverallForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding FlagImagePath}"
                               ToolTip="{Binding NationalityName}"
                               Width="14"
                               Height="10"
                               Stretch="UniformToFill"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PlayerName}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding FatigueWarningBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding FatigueWarningTooltip}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FatigueWarningText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding FatigueWarningText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding FormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding FormBadgeText}"
                                       Foreground="{Binding FormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubstituteCardTemplate">
            <Border Width="128"
                    MinHeight="70"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    Opacity="{Binding CardOpacity}"
                    Cursor="{Binding CardCursor}"
                    ToolTip="{Binding Tooltip}"
                    AllowDrop="{Binding CanInteract}"
                    PreviewMouseLeftButtonDown="SubstituteCard_PreviewMouseLeftButtonDown"
                    MouseMove="SubstituteCard_MouseMove"
                    PreviewDragEnter="SubstituteCard_DragEnter"
                    PreviewDragOver="SubstituteCard_DragOver"
                    PreviewDragLeave="SubstituteCard_DragLeave"
                    PreviewDrop="SubstituteCard_Drop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding OverallText}"
                                       Foreground="{Binding TextForeground}"
                                       FontSize="9.5"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding GrowthText}"
                                       Foreground="#16A34A"
                                       FontSize="7.5"
                                       FontWeight="Black"
                                       Margin="4,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrowthText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{Binding PositionBackground}"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                   Foreground="{Binding PositionForeground}"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding FlagImagePath}"
                               ToolTip="{Binding NationalityName}"
                               Width="14"
                               Height="10"
                               Stretch="UniformToFill"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{Binding TextForeground}"
                                   FontSize="9.2"
                                   FontWeight="Black"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <Border Background="{Binding StatusBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding FatigueWarningBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0"
                                ToolTip="{Binding FatigueWarningTooltip}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FatigueWarningText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding FatigueWarningText}"
                                       Foreground="#FFFFFF"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="{Binding BenchFormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left"
                                Margin="0,0,2,0">
                            <TextBlock Text="{Binding BenchFormBadgeText}"
                                       Foreground="{Binding BenchFormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding TraitBadges}"
                                      ItemTemplate="{StaticResource TraitIconBadgeTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TraitBadges.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="{DynamicResource AppBorderBrush}"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="MainRootGrid"
          Background="{DynamicResource AppPageBackground}"
          Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="FixtureTextBlock"
                               Foreground="#DDF7E8"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />

                    <Button Grid.Column="1"
                            Content="Back to Dashboard"
                            Style="{StaticResource PrimaryTextButton}"
                            Height="34"
                            MinWidth="150"
                            Padding="14,0"
                            FontWeight="SemiBold"
                            Click="BackToDashboardButton_Click" />
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#16894A"
                            BorderBrush="#B8F2CD"
                            BorderThickness="2"
                            CornerRadius="18">
                        <Grid ClipToBounds="True">
                            <Viewbox Stretch="Fill"
                                     IsHitTestVisible="False"
                                     Margin="16">
                                <Canvas Width="1000" Height="680">
                                    <Rectangle Width="1000"
                                               Height="680"
                                               Stroke="#B8F2CD"
                                               StrokeThickness="5"
                                               Opacity="0.72" />
                                    <Line X1="0" Y1="0" X2="1000" Y2="0" Stroke="#B8F2CD" StrokeThickness="5" Opacity="0.72" />
                                    <Ellipse Width="230" Height="230" Canvas.Left="385" Canvas.Top="-115" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.58" />
                                    <Ellipse Width="10" Height="10" Canvas.Left="495" Canvas.Top="-5" Fill="#B8F2CD" Opacity="0.78" />

                                    <Rectangle Width="500" Height="156" Canvas.Left="250" Canvas.Top="524" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.66" />
                                    <Rectangle Width="250" Height="70" Canvas.Left="375" Canvas.Top="610" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.66" />
                                    <Ellipse Width="10" Height="10" Canvas.Left="495" Canvas.Top="557" Fill="#B8F2CD" Opacity="0.72" />
                                    <Path Data="M 414 524 A 96 96 0 0 1 586 524" Stroke="#B8F2CD" StrokeThickness="4" Opacity="0.55" Fill="Transparent" />
                                </Canvas>
                            </Viewbox>
                            <Canvas x:Name="PitchCanvas"
                                    Margin="16"
                                    Background="Transparent"
                                    MouseLeftButtonDown="PitchCanvas_MouseLeftButtonDown"
                                    SizeChanged="PitchCanvas_SizeChanged" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom"
                                    Margin="10,0,0,10"
                                    Padding="7"
                                    CornerRadius="11"
                                    Background="{DynamicResource TacticalFloatingPanelBackground}"
                                    BorderBrush="{DynamicResource TacticalFloatingPanelBorder}"
                                    BorderThickness="1.2"
                                    IsHitTestVisible="False"
                                    Width="190">
                                <Border.Effect>
                                    <DropShadowEffect Color="#071226"
                                                      BlurRadius="16"
                                                      ShadowDepth="2"
                                                      Opacity="0.22" />
                                </Border.Effect>
                                <Grid>
                                    <TextBlock x:Name="SelectedPlayerEmptyTextBlock"
                                               Text="Select a player on the pitch."
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               TextWrapping="Wrap" />

                                    <Grid x:Name="SelectedPlayerCard"
                                          Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock x:Name="SelectedPlayerNumberTextBlock"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="8"
                                                           FontWeight="Bold"
                                                           Visibility="Collapsed" />
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Image x:Name="SelectedPlayerFlagImage"
                                                           Width="18"
                                                           Height="12"
                                                           Stretch="UniformToFill"
                                                           Margin="0,0,5,0"
                                                           VerticalAlignment="Center" />
                                                    <TextBlock x:Name="SelectedPlayerNameTextBlock"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontSize="12"
                                                               FontWeight="Black"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>

                                            <Border x:Name="SelectedPlayerOvrBadgeBorder"
                                                    Grid.Column="1"
                                                    CornerRadius="9"
                                                    Padding="6,3"
                                                    Margin="7,0,0,0"
                                                    VerticalAlignment="Center">
                                                <StackPanel>
                                                    <TextBlock Text="OVR"
                                                               Foreground="White"
                                                               FontSize="6.5"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock x:Name="SelectedPlayerOvrBadgeTextBlock"
                                                               Foreground="White"
                                                               FontSize="12"
                                                               FontWeight="Black"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <WrapPanel Grid.Row="1"
                                                   Margin="0,4,0,0">
                                            <Border Background="{DynamicResource AppPrimaryBrush}"
                                                    CornerRadius="7"
                                                    Padding="5,1"
                                                    Margin="0,0,4,3">
                                                <TextBlock x:Name="SelectedPlayerPositionChip"
                                                           Foreground="{DynamicResource AppInverseTextBrush}"
                                                           FontSize="7.5"
                                                           FontWeight="Bold" />
                                            </Border>
                                            <Border Background="{DynamicResource TacticalOptionBackground}"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,4,4"
                                                    Visibility="Collapsed">
                                                <TextBlock x:Name="SelectedPlayerPreferredChip"
                                                           Foreground="{DynamicResource TacticalOptionForeground}"
                                                           FontSize="9"
                                                           FontWeight="Bold" />
                                            </Border>
                                            <Border x:Name="SelectedPlayerFormChipBorder"
                                                    CornerRadius="7"
                                                    Padding="5,1"
                                                    Margin="0,0,4,3">
                                                <TextBlock x:Name="SelectedPlayerFormChip"
                                                           FontSize="8"
                                                           FontWeight="Bold" />
                                            </Border>
                                            <ItemsControl x:Name="SelectedPlayerTraitItemsControl"
                                                          ItemTemplate="{StaticResource TraitIconBadgeTemplate}"
                                                          Margin="0,1,4,4"
                                                          Visibility="Collapsed">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                            <Border x:Name="SelectedPlayerInjuryChipBorder"
                                                    Background="{DynamicResource TacticalOptionBackground}"
                                                    CornerRadius="8"
                                                    Padding="6,2"
                                                    Margin="0,0,4,4"
                                                    Visibility="Collapsed">
                                                <TextBlock x:Name="SelectedPlayerInjuryChip"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="9"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </WrapPanel>

                                        <StackPanel Grid.Row="2"
                                                    Margin="0,2,0,0">
                                            <Grid Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Stamina"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="9"
                                                           FontWeight="Bold" />
                                                <TextBlock x:Name="SelectedPlayerStaminaTextBlock"
                                                           Grid.Column="1"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="9"
                                                           FontWeight="Bold" />
                                            </Grid>

                                            <Grid Margin="0,1,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar x:Name="SelectedPlayerStaminaFill"
                                                         Height="5"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding Stamina}"
                                                         Foreground="#2FA84F"
                                                         Background="{DynamicResource TacticalOptionBackground}"
                                                         BorderThickness="0"
                                                         Margin="0,0,8,0" />
                                                <TextBlock x:Name="SelectedPlayerStaminaPercentTextBlock"
                                                           Grid.Column="1"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                                           FontSize="8"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                            </Grid>

                                            <UniformGrid Columns="4"
                                                         Margin="0,4,0,0">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="⚔" Foreground="{DynamicResource AppAccentBrush}" FontSize="8.5" FontWeight="Bold" Margin="0,0,2,0" />
                                                    <TextBlock x:Name="SelectedPlayerAttackTextBlock" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="🛡" Foreground="{DynamicResource AppAccentBrush}" FontSize="8.5" FontWeight="Bold" Margin="0,0,2,0" />
                                                    <TextBlock x:Name="SelectedPlayerDefenseTextBlock" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="🅿" Foreground="{DynamicResource AppAccentBrush}" FontSize="8.5" FontWeight="Bold" Margin="0,0,2,0" />
                                                    <TextBlock x:Name="SelectedPlayerPassingTextBlock" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="🎯" Foreground="{DynamicResource AppAccentBrush}" FontSize="8.5" FontWeight="Bold" Margin="0,0,2,0" />
                                                    <TextBlock x:Name="SelectedPlayerFinishingTextBlock" FontSize="8" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                                                </StackPanel>
                                            </UniformGrid>
                                        </StackPanel>

                                        <Image x:Name="SelectedPlayerImage"
                                               Visibility="Collapsed" />
                                    </Grid>
                                </Grid>
                            </Border>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,18,18"
                                    Padding="10,8"
                                    CornerRadius="13"
                                    Background="{DynamicResource TacticalFloatingPanelBackground}"
                                    BorderBrush="{DynamicResource TacticalFloatingPanelBorder}"
                                    BorderThickness="1.2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#071226"
                                                      BlurRadius="16"
                                                      ShadowDepth="2"
                                                      Opacity="0.26" />
                                </Border.Effect>
                                <StackPanel Width="168">
                                    <TextBlock Text="Formation ⚽"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Margin="0,0,0,4" />
                                    <ComboBox x:Name="FormationComboBox"
                                              Height="28"
                                              FontSize="12"
                                              SelectionChanged="FormationComboBox_SelectionChanged">
                                        <ComboBox.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10"
                                                                   FontWeight="Black"
                                                                   Foreground="#2563EB"
                                                                   Margin="6,6,0,3" />
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ComboBox.GroupStyle>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0F6D39"
                            BorderBrush="#B8F2CD"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Substitutes"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="SubstituteFilterTextBlock"
                                       Grid.Column="1"
                                       Text="All players"
                                       Foreground="#DDF7E8"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button x:Name="ClearSubstituteFilterButton"
                                    Grid.Column="2"
                                    Content="x"
                                    Width="22"
                                    Height="22"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    FontSize="11"
                                    FontWeight="Black"
                                    ToolTip="Show all substitutes"
                                    Visibility="Collapsed"
                                    Click="ClearSubstituteFilterButton_Click" />
                        </Grid>

                        <ListBox x:Name="SubstituteListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 AllowDrop="True"
                                 PreviewDragEnter="SubstituteListBox_DragEnter"
                                 PreviewDragOver="SubstituteListBox_DragOver"
                                 PreviewDragLeave="SubstituteListBox_DragLeave"
                                 PreviewDrop="SubstituteListBox_Drop"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Opacity" Value="0.94" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="SubstituteCardTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="{DynamicResource AppCardBackground}"
                CornerRadius="18"
                Padding="16">
            <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tactic"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TacticalInsightInfoIcon"
                                   Grid.Column="1"
                                   Text="ⓘ"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   ToolTipService.ShowDuration="30000" />
                        <Button x:Name="ToggleSavedFormationsButton"
                                Grid.Column="3"
                                Content="Formation ▼"
                                Style="{StaticResource SavedFormationLoadButtonStyle}"
                                Height="28"
                                Padding="10,0"
                                Margin="8,0,0,0"
                                FontSize="11"
                                Click="ToggleSavedFormationsButton_Click" />
                    </Grid>

                    <Border x:Name="SavedFormationsPanel"
                            Background="{DynamicResource AppSecondaryCardBackground}"
                            BorderBrush="{DynamicResource AppCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10"
                            Margin="0,0,0,10"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Saved Formations"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Margin="0,0,0,6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="SavedFormationComboBox"
                                          Height="30"
                                          DisplayMemberPath="Name"
                                          ToolTip="Choose a saved formation preset" />
                                <Button x:Name="LoadSavedFormationButton"
                                        Grid.Column="1"
                                        Content="Load"
                                        Style="{StaticResource SavedFormationLoadButtonStyle}"
                                        Margin="6,0,0,0"
                                        Click="LoadSavedFormationButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <controls:TacticalSettingsPanel x:Name="TacticalSettingsPanel"
                                                    PanelMaxHeight="350"
                                                    TacticsChanged="TacticalSettingsPanel_TacticsChanged" />

                    <Button Content="Start First Half"
                            Style="{StaticResource PrimaryTextButton}"
                            Height="40"
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Click="StartFirstHalfButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
