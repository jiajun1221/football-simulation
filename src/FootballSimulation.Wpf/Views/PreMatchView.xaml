<UserControl x:Class="FootballSimulation.Wpf.Views.PreMatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="PitchPlayerCardTemplate">
            <Border Width="112"
                    Height="72"
                    Background="{Binding CardBackground}"
                    BorderBrush="{Binding CardBorderBrush}"
                    BorderThickness="{Binding CardBorderThickness}"
                    CornerRadius="10"
                    Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="#143052"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding OverallText}"
                                   Foreground="{Binding OverallForeground}"
                                   FontSize="9.5"
                                   FontWeight="Black"
                                   VerticalAlignment="Center" />

                        <Border Grid.Column="2"
                                Background="#E7EEF8"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding PositionText}"
                                       Foreground="#071A2E"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding PlayerName}"
                               Foreground="#102033"
                               FontSize="9.2"
                               FontWeight="Black"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />

                    <Grid Grid.Row="2" Margin="0,3,0,0">
                        <Border Background="{Binding FormBadgeBackground}"
                                CornerRadius="7"
                                Padding="5,1"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding FormBadgeText}"
                                       Foreground="{Binding FormBadgeForeground}"
                                       FontSize="7"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="#DDE5EF"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SubstituteCardTemplate">
            <Border Width="128"
                    Height="78"
                    Background="White"
                    BorderBrush="#D6DFEA"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="6"
                    Margin="0,0,0,7"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="SubstituteCard_PreviewMouseLeftButtonDown"
                    MouseMove="SubstituteCard_MouseMove"
                    PreviewDragEnter="SubstituteCard_DragEnter"
                    PreviewDragOver="SubstituteCard_DragOver"
                    PreviewDragLeave="SubstituteCard_DragLeave"
                    PreviewDrop="SubstituteCard_Drop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ShirtNumberText}"
                                   Foreground="#143052"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding OverallText}"
                                   Foreground="#071A2E"
                                   FontSize="9.5"
                                   FontWeight="Black"
                                   VerticalAlignment="Center" />

                        <Border Grid.Column="2"
                                Background="#E7EEF8"
                                CornerRadius="7"
                                Padding="5,1">
                            <TextBlock Text="{Binding Position}"
                                   Foreground="#102033"
                                       FontSize="7.5"
                                       FontWeight="Black" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding Name}"
                               Foreground="#102033"
                               FontSize="9.2"
                               FontWeight="Black"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Margin="0,4,0,0" />

                    <Border Grid.Row="2"
                            Background="{Binding BenchFormBadgeBackground}"
                            CornerRadius="7"
                            Padding="5,1"
                            HorizontalAlignment="Left"
                            Margin="0,3,0,0">
                        <TextBlock Text="{Binding BenchFormBadgeText}"
                                   Foreground="{Binding BenchFormBadgeForeground}"
                                   FontSize="7"
                                   FontWeight="Bold" />
                    </Border>

                    <ProgressBar Grid.Row="3"
                                 Height="5"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Stamina}"
                                 Foreground="{Binding StaminaBrush}"
                                 Background="#DDE5EF"
                                 BorderThickness="0"
                                 Margin="0,5,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="MainRootGrid" Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E7A3C"
                CornerRadius="18"
                Padding="18"
                Margin="0,0,18,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,10">
                    <TextBlock x:Name="FixtureTextBlock"
                               Foreground="#DDF7E8"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#16894A"
                            BorderBrush="#B8F2CD"
                            BorderThickness="2"
                            CornerRadius="18">
                        <Grid>
                            <Line X1="0" Y1="0" X2="900" Y2="0" Stroke="#8FE2AE" Opacity="0.45" />
                            <Line X1="0" Y1="260" X2="900" Y2="260" Stroke="#8FE2AE" Opacity="0.35" />
                            <Ellipse Width="110"
                                     Height="110"
                                     Stroke="#8FE2AE"
                                     StrokeThickness="2"
                                     Opacity="0.45"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Canvas x:Name="PitchCanvas"
                                    Margin="16"
                                    SizeChanged="PitchCanvas_SizeChanged" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0F6D39"
                            BorderBrush="#B8F2CD"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock Text="Substitutes"
                                       Foreground="White"
                                       FontSize="17"
                                       FontWeight="Bold" />
                        </Grid>

                        <ListBox x:Name="SubstituteListBox"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 AllowDrop="True"
                                 PreviewDragEnter="SubstituteListBox_DragEnter"
                                 PreviewDragOver="SubstituteListBox_DragOver"
                                 PreviewDragLeave="SubstituteListBox_DragLeave"
                                 PreviewDrop="SubstituteListBox_Drop"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="True">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,6" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Opacity" Value="0.94" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="SubstituteCardTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="White"
                CornerRadius="18"
                Padding="16">
            <StackPanel>
                    <TextBlock Text="Setup"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Selected Player"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,5" />
                    <Border Background="#F3F6FA"
                            CornerRadius="12"
                            Padding="9"
                            Margin="0,0,0,10">
                        <Grid>
                            <TextBlock x:Name="SelectedPlayerEmptyTextBlock"
                                       Text="Select a player on the pitch."
                                       FontSize="11"
                                       Foreground="#607187"
                                       TextWrapping="Wrap" />

                            <Grid x:Name="SelectedPlayerCard"
                                  Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="40"
                                            Height="40"
                                            Background="#E7EEF8"
                                            BorderBrush="#D6DFEA"
                                            BorderThickness="1"
                                            CornerRadius="11"
                                            VerticalAlignment="Top">
                                        <Image x:Name="SelectedPlayerImage"
                                               Stretch="UniformToFill"
                                               Margin="4" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="7,0,0,0">
                                        <TextBlock x:Name="SelectedPlayerNumberTextBlock"
                                                   Foreground="#607187"
                                                   FontSize="10"
                                                   FontWeight="Bold" />
                                        <TextBlock x:Name="SelectedPlayerNameTextBlock"
                                                   Foreground="#071A2E"
                                                   FontSize="14"
                                                   FontWeight="Black"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border x:Name="SelectedPlayerOvrBadgeBorder"
                                            Grid.Column="2"
                                            CornerRadius="10"
                                            Padding="8,5"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Top">
                                        <StackPanel>
                                            <TextBlock Text="OVR"
                                                       Foreground="White"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock x:Name="SelectedPlayerOvrBadgeTextBlock"
                                                       Foreground="White"
                                                       FontSize="16"
                                                       FontWeight="Black"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <WrapPanel Grid.Row="1"
                                           Margin="0,7,0,0">
                                    <Border Background="#102033"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,4,4">
                                        <TextBlock x:Name="SelectedPlayerPositionChip"
                                                   Foreground="White"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <Border Background="#E7EEF8"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,4,4">
                                        <TextBlock x:Name="SelectedPlayerPreferredChip"
                                                   Foreground="#102033"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                    <Border x:Name="SelectedPlayerFormChipBorder"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,4,4">
                                        <TextBlock x:Name="SelectedPlayerFormChip"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Border>
                                     <Border x:Name="SelectedPlayerInjuryChipBorder"
                                            Background="#D9F1E1"
                                            CornerRadius="8"
                                            Padding="6,2"
                                            Margin="0,0,4,4">
                                        <TextBlock x:Name="SelectedPlayerInjuryChip"
                                                   Foreground="#236B39"
                                                   FontSize="9"
                                                    FontWeight="Bold" />
                                     </Border>
                                 </WrapPanel>

                                <StackPanel Grid.Row="2" Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Stamina"
                                                   Foreground="#607187"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                        <TextBlock x:Name="SelectedPlayerStaminaTextBlock"
                                                   Grid.Column="1"
                                                   Foreground="#34465C"
                                                   FontSize="9"
                                                   FontWeight="Bold" />
                                    </Grid>

                                    <ProgressBar x:Name="SelectedPlayerStaminaFill"
                                                 Height="7"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding Stamina}"
                                                 Foreground="#2FA84F"
                                                 Background="#DDE5EF"
                                                 BorderThickness="0"
                                                 Margin="0,3,0,7" />

                                    <UniformGrid Columns="2">
                                        <TextBlock x:Name="SelectedPlayerAttackTextBlock" FontSize="10" Foreground="#34465C" Margin="0,0,0,2" />
                                        <TextBlock x:Name="SelectedPlayerDefenseTextBlock" FontSize="10" Foreground="#34465C" Margin="0,0,0,2" />
                                        <TextBlock x:Name="SelectedPlayerPassingTextBlock" FontSize="10" Foreground="#34465C" />
                                        <TextBlock x:Name="SelectedPlayerFinishingTextBlock" FontSize="10" Foreground="#34465C" />
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Text="Formation"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="#102033"
                               Margin="0,0,0,1" />
                    <ComboBox x:Name="FormationComboBox"
                              Height="30"
                              Margin="0,3,0,8"
                              SelectionChanged="FormationComboBox_SelectionChanged" />

                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tactics"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#102033"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TacticalInsightInfoIcon"
                                   Grid.Column="1"
                                   Text="ⓘ"
                                   Foreground="#607187"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"
                                   ToolTipService.ShowDuration="30000" />
                    </Grid>

                    <TextBlock Text="Mentality" FontSize="12" FontWeight="SemiBold" Foreground="#102033" />
                    <ComboBox x:Name="MentalityComboBox"
                              Height="30"
                              Margin="0,3,0,7"
                              SelectionChanged="TacticsControl_Changed" />

                    <TextBlock Text="Pressing Intensity" FontSize="12" FontWeight="SemiBold" Foreground="#102033" />
                    <Slider x:Name="PressingSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Width" FontSize="12" FontWeight="SemiBold" Foreground="#102033" Margin="0,3,0,0" />
                    <Slider x:Name="WidthSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Tempo" FontSize="12" FontWeight="SemiBold" Foreground="#102033" Margin="0,3,0,0" />
                    <Slider x:Name="TempoSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <TextBlock Text="Defensive Line" FontSize="12" FontWeight="SemiBold" Foreground="#102033" Margin="0,3,0,0" />
                    <Slider x:Name="DefensiveLineSlider" Height="20" Minimum="1" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False" />

                    <Button Content="Start First Half"
                            Height="40"
                            Margin="0,8,0,0"
                            FontWeight="SemiBold"
                            Click="StartFirstHalfButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
