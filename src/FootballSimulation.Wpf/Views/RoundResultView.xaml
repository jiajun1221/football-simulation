<UserControl x:Class="FootballSimulation.Wpf.Views.RoundResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ResultCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="CleanDataGrid" TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="CanUserResizeRows" Value="False" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#102033"
                CornerRadius="22"
                Padding="26">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold" />
                <TextBlock Text="All matches from this round have been completed."
                           Foreground="#CFE3FF"
                           FontSize="15"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.85*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ResultCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Round Results"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,14" />
                    <ListBox x:Name="RoundResultsListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="15" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ResultCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Updated League Table"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#102033"
                               Margin="0,0,0,14" />
                    <DataGrid x:Name="LeagueTableDataGrid"
                              Grid.Row="1"
                              Style="{StaticResource CleanDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Club" Binding="{Binding TeamName}" Width="*" />
                            <DataGridTextColumn Header="MP" Binding="{Binding Played}" Width="48" />
                            <DataGridTextColumn Header="W" Binding="{Binding Wins}" Width="42" />
                            <DataGridTextColumn Header="D" Binding="{Binding Draws}" Width="42" />
                            <DataGridTextColumn Header="L" Binding="{Binding Losses}" Width="42" />
                            <DataGridTextColumn Header="GF" Binding="{Binding GoalsFor}" Width="48" />
                            <DataGridTextColumn Header="GA" Binding="{Binding GoalsAgainst}" Width="48" />
                            <DataGridTextColumn Header="GD" Binding="{Binding GoalDifference}" Width="52" />
                            <DataGridTextColumn Header="Pts" Binding="{Binding Points}" Width="56" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="4"
                Content="Next"
                Width="180"
                Height="46"
                HorizontalAlignment="Right"
                Background="#102033"
                Foreground="White"
                FontWeight="Bold"
                BorderThickness="0"
                Click="NextButton_Click" />
    </Grid>
</UserControl>
