<Window x:Class="FootballSimulation.Wpf.Views.SaveSlotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Game"
        Height="430"
        Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppPageBackground}">
    <Window.Resources>
        <Style x:Key="SaveSlotActionButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="SaveSlotDialogCardTemplate">
            <Border Background="{DynamicResource AppCardBackground}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="18"
                    Margin="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding SlotTitle}"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppTextBrush}" />

                    <StackPanel Grid.Row="1" Margin="0,16">
                        <TextBlock Text="{Binding ClubName}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SummaryText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="{Binding SavedAtText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                    </StackPanel>

                    <Button Grid.Row="2"
                            Style="{StaticResource SaveSlotActionButton}"
                            Content="{Binding ButtonText}"
                            Click="SelectSlotButton_Click" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Save Game"
                       FontSize="27"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="Choose one of three slots. Existing saves will ask for overwrite confirmation."
                       FontSize="13"
                       Foreground="{DynamicResource AppMutedTextBrush}"
                       Margin="0,6,0,0" />
        </StackPanel>

        <ItemsControl x:Name="SaveSlotsItemsControl"
                      Grid.Row="1"
                      ItemTemplate="{StaticResource SaveSlotDialogCardTemplate}"
                      VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <Button Grid.Row="2"
                Content="Cancel"
                Width="110"
                Height="40"
                HorizontalAlignment="Right"
                Background="{DynamicResource AppSecondaryCardBackground}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                Foreground="{DynamicResource AppTextBrush}"
                Click="CancelButton_Click" />
    </Grid>
</Window>
