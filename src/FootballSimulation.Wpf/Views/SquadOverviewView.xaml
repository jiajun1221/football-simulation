<UserControl x:Class="FootballSimulation.Wpf.Views.SquadOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls"
             xmlns:views="clr-namespace:FootballSimulation.Wpf.Views"
             Background="{DynamicResource AppPageBackground}">
    <UserControl.Resources>
        <DropShadowEffect x:Key="SoftCardShadow"
                          BlurRadius="18"
                          ShadowDepth="3"
                          Opacity="0.12"
                          Color="#0F172A" />

        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#061226" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#061226" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="160" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E293B" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OvrBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#061226" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CenteredGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>

        <Style x:Key="CenteredValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CenteredGridTextStyle}">
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <DataTemplate x:Key="TransferPlayerCellTemplate">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Visibility="{Binding CaptainBadgeVisibility}"
                        Background="#061226"
                        BorderBrush="#061226"
                        BorderThickness="1"
                        CornerRadius="8"
                        Width="24"
                        Height="22"
                        Margin="0,0,7,0"
                        ToolTip="{Binding CaptainBadgeTooltip}">
                    <TextBlock Text="C"
                               Foreground="#FFFFFF"
                               FontSize="11"
                               FontWeight="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding PlayerName}"
                           ToolTip="{Binding PlayerName}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="StatusCellTemplate">
            <Border Background="{Binding StatusBrush}"
                    CornerRadius="10"
                    Height="24"
                    Padding="9,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip="{Binding StatusTooltip}">
                <TextBlock Text="{Binding Status}"
                           Foreground="#FFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="NationalityCellTemplate">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Image Source="{Binding NationalityFlagImagePath}"
                       ToolTip="{Binding NationalityName}"
                       Width="24"
                       Height="16"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <Style x:Key="SegmentedTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="98" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#344054" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="SegmentBorder"
                                Height="{TemplateBinding Height}"
                                MinWidth="{TemplateBinding MinWidth}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       FontSize="{TemplateBinding FontSize}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="#FFFFFF" />
                                <Setter Property="Foreground" Value="#061226" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="#061226" />
                                <Setter TargetName="SegmentBorder" Property="Effect" Value="{StaticResource SoftCardShadow}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="0,0,5,5" />
            <Setter Property="Background" Value="#061226" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#061226" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ModernGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeight" Value="46" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Height" Value="40" />
                        <Setter Property="Padding" Value="10,6" />
                        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="6,0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource TableAlternateRowBackground}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0F2FE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DBEAFE" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="22,16,22,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="Back to Dashboard"
                    Style="{StaticResource BackButtonStyle}"
                    Click="BackToDashboardButton_Click"
                    DockPanel.Dock="Right" />
            <StackPanel>
                <TextBlock Text="My Squad"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppTextBrush}" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="#EAF0F7"
                CornerRadius="14"
                Padding="4"
                HorizontalAlignment="Left"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="SquadSegmentButton"
                             Content="Squad"
                             GroupName="SquadTabs"
                             Tag="0"
                             IsChecked="True"
                             Style="{StaticResource SegmentedTabButtonStyle}"
                             Click="SquadTabButton_Click" />
                <RadioButton x:Name="FormationSegmentButton"
                             Content="Formation"
                             GroupName="SquadTabs"
                             Tag="1"
                             Style="{StaticResource SegmentedTabButtonStyle}"
                             Click="SquadTabButton_Click" />
            </StackPanel>
        </Border>

        <TabControl x:Name="SquadTabControl"
                    Grid.Row="2"
                    SelectedIndex="0"
                    Style="{StaticResource ModernTabControlStyle}"
                    SelectionChanged="SquadTabControl_SelectionChanged">
            <TabItem Header="Squad">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72*" />
                        <ColumnDefinition Width="28*" />
                    </Grid.ColumnDefinitions>

                    <DataGrid x:Name="SquadDataGrid"
                              Grid.Column="0"
                              Style="{StaticResource ModernGridStyle}"
                              CellEditEnding="SquadDataGrid_CellEditEnding"
                              SelectionChanged="SquadDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding ShirtNumber, UpdateSourceTrigger=PropertyChanged}" Width="54" ElementStyle="{StaticResource CenteredValueTextStyle}" />
                            <DataGridTemplateColumn Header="Player" Width="175" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <StaticResource ResourceKey="TransferPlayerCellTemplate" />
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Nat" Width="42" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <StaticResource ResourceKey="NationalityCellTemplate" />
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Pos" Binding="{Binding Position}" Width="45" ElementStyle="{StaticResource CenteredGridTextStyle}" IsReadOnly="True" />
                            <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="45" ElementStyle="{StaticResource CenteredGridTextStyle}" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="OVR" Width="58" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource OvrBadgeBorderStyle}">
                                            <TextBlock Text="{Binding OverallText}" Foreground="#FFFFFF" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Form" Width="78" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding FormBrush}" CornerRadius="10" Height="24" Padding="7,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Form}" Foreground="{Binding FormTextBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Value" Width="88" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MarketValueText}" Style="{StaticResource CenteredValueTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Exp." Binding="{Binding ContractText}" Width="76" ElementStyle="{StaticResource CenteredGridTextStyle}" IsReadOnly="True" />
                            <DataGridTextColumn Header="Wage" Binding="{Binding WageText}" Width="78" ElementStyle="{StaticResource CenteredValueTextStyle}" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Status" Width="100" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <StaticResource ResourceKey="StatusCellTemplate" />
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <views:TransferPlayerDetailPanel x:Name="SquadDetailPanel" Grid.Column="1" />
                </Grid>
            </TabItem>

            <TabItem Header="Formation">
                <controls:FormationSetupPanel x:Name="FormationSetupPanel"
                                              SetupChanged="FormationSetupPanel_SetupChanged" />
            </TabItem>
        </TabControl>

        <Border x:Name="CaptainToastBorder"
                Grid.RowSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,48,24,0"
                Background="#061226"
                BorderBrush="#233756"
                BorderThickness="1"
                CornerRadius="14"
                Padding="16,10"
                Visibility="Collapsed"
                Panel.ZIndex="20"
                Effect="{StaticResource SoftCardShadow}">
            <TextBlock x:Name="CaptainToastTextBlock"
                       Foreground="#FFFFFF"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</UserControl>
