<UserControl x:Class="FootballSimulation.Wpf.Views.TeamSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ClubCardItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder"
                                MinHeight="106"
                                Background="#FFFFFF"
                                BorderBrush="#D7E0EC"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Panel.ZIndex" Value="4" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#63B3ED" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18"
                                                          Direction="270"
                                                          ShadowDepth="0"
                                                          Color="#4AA3FF"
                                                          Opacity="0.35" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="6" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.07" ScaleY="1.07" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CardBorder" Property="Background" Value="#EAF4FF" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#0EA5E9" />
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="3" />
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="24"
                                                          Direction="270"
                                                          ShadowDepth="0"
                                                          Color="#0EA5E9"
                                                          Opacity="0.42" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#E9EEF5">
        <Grid Margin="20,18,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Choose Your Club"
                       Foreground="#0B1B2E"
                       FontSize="34"
                       FontWeight="Bold"
                       Margin="4,0,0,14" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Border Background="#0F1B2D"
                        CornerRadius="28"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="4,0,4,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Premier League Clubs"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="1"
                                       Text="Pick one club"
                                       Foreground="#9FB2C9"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <ListBox x:Name="ClubListBox"
                                 Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource ClubCardItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="ClubListBox_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="74" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Image Source="{Binding LogoSource}"
                                               Width="56"
                                               Height="56"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Name}"
                                                   Foreground="#0B1B2E"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="28"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Selected Club"
                                   Foreground="#647084"
                                   FontSize="13"
                                   FontWeight="Bold" />

                        <Border Grid.Row="2"
                                Width="122"
                                Height="122"
                                Background="#F1F6FC"
                                CornerRadius="61"
                                HorizontalAlignment="Center">
                            <Image x:Name="SelectedClubLogoImage"
                                   Width="94"
                                   Height="94"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Row="4">
                            <TextBlock x:Name="ClubNameTextBlock"
                                       Text="Select a club"
                                       Foreground="#0B1B2E"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />

                            <TextBlock x:Name="StadiumTextBlock"
                                       Text="Choose a club from the grid"
                                       Foreground="#697A90"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0" />

                            <TextBlock x:Name="CityTextBlock"
                                       Text=""
                                       Foreground="#8A98AA"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <Border Grid.Row="6"
                                Background="#F4F7FB"
                                BorderBrush="#DDE7F3"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="14">
                            <StackPanel>
                                <TextBlock Text="Squad Rating"
                                           Foreground="#607187"
                                           FontSize="12"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="SquadRatingTextBlock"
                                           Text="-"
                                           Foreground="#102033"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8" />
                                <TextBlock x:Name="ClubDescriptionTextBlock"
                                           Text="Club details will appear here after selection."
                                           Foreground="#526579"
                                           FontSize="13"
                                           LineHeight="18"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Button x:Name="StartCareerButton"
                                Grid.Row="8"
                                Content="Start Career"
                                Height="48"
                                Background="#0B1B2E"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                IsEnabled="False"
                                Click="StartCareerButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
