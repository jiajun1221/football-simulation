<UserControl x:Class="FootballSimulation.Wpf.Views.TransferPlayerDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FootballSimulation.Wpf.Controls">
    <UserControl.Resources>
        <DropShadowEffect x:Key="DetailCardShadow"
                          BlurRadius="18"
                          ShadowDepth="3"
                          Opacity="0.12"
                          Color="#0F172A" />

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Effect" Value="{StaticResource DetailCardShadow}" />
        </Style>

        <Style x:Key="DetailMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DetailLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource DetailMutedTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="DetailSectionHeaderStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,12,0,7" />
        </Style>

        <Style x:Key="DetailSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0B1B33" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailSectionIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailSectionDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="#D8E0EA" />
            <Setter Property="Margin" Value="9,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="{DynamicResource AppInputBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="DetailPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5E7EB" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D1D5DB" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DetailPrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AppCardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}" />
        </Style>

        <Style x:Key="DetailDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource DetailPrimaryButtonStyle}">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
        </Style>

        <Style x:Key="DetailOvrBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#061226" />
            <Setter Property="BorderBrush" Value="#1E293B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="DetailCornerActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#061226" />
            <Setter Property="BorderBrush" Value="#233756" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="7"
                                      ShadowDepth="1"
                                      Opacity="0.45"
                                      Color="#0F172A" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12"
                                                          ShadowDepth="0"
                                                          Opacity="0.55"
                                                          Color="#22C55E" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource DetailCardStyle}" Margin="14,0,0,0">
        <Grid>
            <StackPanel x:Name="EmptyStatePanel"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,28,0,0">
                <TextBlock Text="Select a player"
                           TextAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <TextBlock Text="Details will appear here."
                           Style="{StaticResource DetailMutedTextStyle}"
                           TextAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Grid x:Name="DetailContentPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,12">
                        <DockPanel Margin="0,0,30,0">
                            <Image x:Name="ClubLogoImage"
                                   Width="42"
                                   Height="42"
                                   Stretch="Uniform"
                                   Margin="0,0,10,0"
                                   DockPanel.Dock="Left" />
                            <StackPanel>
                                <TextBlock x:Name="NameTextBlock"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="ClubTextBlock"
                                           Style="{StaticResource DetailMutedTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>

                        <WrapPanel Margin="0,10,0,8">
                            <Border Style="{StaticResource DetailOvrBadgeBorderStyle}" Margin="0,0,6,6">
                                <TextBlock x:Name="OverallBadgeTextBlock"
                                           Foreground="#FFFFFF"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="FormBadgeBorder" Background="#FACC15" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                                <TextBlock x:Name="FormBadgeTextBlock" Foreground="#FFFFFF" FontWeight="Bold" />
                            </Border>
                            <Border x:Name="StatusBadgeBorder" Background="#10B981" CornerRadius="10" Padding="8,3" Margin="0,0,6,6">
                                <TextBlock x:Name="StatusBadgeTextBlock" Foreground="#FFFFFF" FontWeight="Bold" />
                            </Border>
                            <Border x:Name="NationalityBadgeBorder"
                                    Background="{DynamicResource AppCardBackground}"
                                    BorderBrush="{DynamicResource AppCardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    Margin="0,0,6,6">
                                <StackPanel Orientation="Horizontal">
                                    <controls:FlagBadge x:Name="NationalityFlagImage"
                                                        Width="24"
                                                        Height="16"
                                                        Margin="0,0,6,0"
                                                        VerticalAlignment="Center" />
                                    <TextBlock x:Name="NationalityBadgeTextBlock"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="ContractBadgeBorder"
                                    Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    Margin="0,0,6,6">
                                <TextBlock x:Name="ContractBadgeTextBlock"
                                           Foreground="#1D4ED8"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    Margin="0,0,6,6">
                                <TextBlock x:Name="WageBadgeTextBlock"
                                           Foreground="#0F172A"
                                           FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>

                        <Grid Style="{StaticResource DetailSectionHeaderStyle}" Margin="0,4,0,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⭐" Style="{StaticResource DetailSectionIconStyle}" />
                            <TextBlock Grid.Column="1" Text="Traits" Style="{StaticResource DetailSectionTitleStyle}" />
                            <Border Grid.Column="2" Style="{StaticResource DetailSectionDividerStyle}" />
                        </Grid>
                        <ItemsControl x:Name="TraitsItemsControl" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F1F5F9"
                                            CornerRadius="10"
                                            Padding="7,3"
                                            Margin="0,0,5,5"
                                            ToolTip="{Binding Tooltip}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="#0F172A"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Style="{StaticResource DetailSectionHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⚡" Style="{StaticResource DetailSectionIconStyle}" />
                            <TextBlock Grid.Column="1" Text="Attributes" Style="{StaticResource DetailSectionTitleStyle}" />
                            <Border Grid.Column="2" Style="{StaticResource DetailSectionDividerStyle}" />
                        </Grid>
                        <ItemsControl x:Name="AttributeItemsControl" Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,10,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontSize="12"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#061226"
                                                CornerRadius="8"
                                                MinWidth="30"
                                                Height="22"
                                                Padding="7,0">
                                            <TextBlock Text="{Binding Value}"
                                                       Foreground="#FFFFFF"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Style="{StaticResource DetailSectionHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📊" Style="{StaticResource DetailSectionIconStyle}" />
                            <TextBlock Grid.Column="1" Text="Season Stats" Style="{StaticResource DetailSectionTitleStyle}" />
                            <Border Grid.Column="2" Style="{StaticResource DetailSectionDividerStyle}" />
                        </Grid>
                        <UniformGrid Columns="4" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Goals" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="GoalsTextBlock" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Assists" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="AssistsTextBlock" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Matches" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="MatchesTextBlock" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Avg" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="RatingTextBlock" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                            </StackPanel>
                        </UniformGrid>

                        <Grid Style="{StaticResource DetailSectionHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💰" Style="{StaticResource DetailSectionIconStyle}" />
                            <TextBlock Grid.Column="1" Text="Market Info" Style="{StaticResource DetailSectionTitleStyle}" />
                            <Border Grid.Column="2" Style="{StaticResource DetailSectionDividerStyle}" />
                        </Grid>
                        <UniformGrid Columns="3" Margin="0,0,0,10">
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="Market Value" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="MarketValueTextBlock" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextBrush}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock x:Name="PriceLabelTextBlock" Style="{StaticResource DetailMutedTextStyle}" />
                                <TextBlock x:Name="PriceTextBlock" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppAccentBrush}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Difficulty" Style="{StaticResource DetailMutedTextStyle}" />
                                <Border x:Name="NegotiationDifficultyBadgeBorder"
                                        CornerRadius="9"
                                        Padding="8,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="NegotiationDifficultyTextBlock"
                                               Foreground="#FFFFFF"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </UniformGrid>

                        <Grid Style="{StaticResource DetailSectionHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📄" Style="{StaticResource DetailSectionIconStyle}" />
                            <TextBlock Grid.Column="1" Text="Contract" Style="{StaticResource DetailSectionTitleStyle}" />
                            <Border Grid.Column="2" Style="{StaticResource DetailSectionDividerStyle}" />
                        </Grid>
                        <WrapPanel Margin="0,0,0,10">
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock x:Name="ContractExpiryTextBlock" Foreground="#1D4ED8" FontWeight="Bold" />
                            </Border>
                            <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock x:Name="ContractWageTextBlock" Foreground="#0F172A" FontWeight="Bold" />
                            </Border>
                            <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock x:Name="ContractRoleTextBlock" Foreground="#0F172A" FontWeight="Bold" />
                            </Border>
                            <Border x:Name="ReleaseClauseBadgeBorder" Background="#FEF3C7" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                <TextBlock x:Name="ReleaseClauseTextBlock" Foreground="#92400E" FontWeight="Bold" />
                            </Border>
                        </WrapPanel>
                        <TextBlock x:Name="ContractWarningTextBlock"
                                   Foreground="#B45309"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,10" />

                        <TextBlock x:Name="RecommendationTextBlock"
                                   Foreground="#2563EB"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,10" />
                        <StackPanel x:Name="OfferInfoPanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock x:Name="OfferInfoTitleTextBlock" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock x:Name="OfferInfoTextBlock"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1">
                    <StackPanel x:Name="TransferActionPanel" Visibility="Collapsed">
                        <TextBlock Text="Offer Amount" Style="{StaticResource DetailLabelStyle}" />
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="€" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBox x:Name="OfferFeeTextBox"
                                     Style="{StaticResource DetailTextBoxStyle}"
                                     Padding="28,4,10,4"
                                     ToolTip="Offer fee in millions" />
                        </Grid>
                        <Button x:Name="MakeOfferButton"
                                Content="Make Offer"
                                Style="{StaticResource DetailPrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Click="MakeOfferButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="SquadActionPanel" Visibility="Collapsed">
                        <TextBlock Text="Contract Extension" Style="{StaticResource DetailLabelStyle}" />
                        <UniformGrid Columns="3" Margin="0,0,0,8">
                            <TextBox x:Name="RenewalWageTextBox"
                                     Style="{StaticResource DetailTextBoxStyle}"
                                     Margin="0,0,6,0"
                                     ToolTip="Weekly wage in thousands" />
                            <ComboBox x:Name="RenewalYearsComboBox"
                                      Height="30"
                                      Padding="7,2"
                                      Background="{DynamicResource AppInputBackground}"
                                      Foreground="{DynamicResource AppTextBrush}"
                                      Margin="0,0,6,0"
                                      ToolTip="Contract length" />
                            <ComboBox x:Name="RenewalRoleComboBox"
                                      Height="30"
                                      Padding="7,2"
                                      Background="{DynamicResource AppInputBackground}"
                                      Foreground="{DynamicResource AppTextBrush}"
                                      ToolTip="Squad role" />
                        </UniformGrid>
                        <Button x:Name="RenewContractButton"
                                Content="Offer Extension"
                                Style="{StaticResource DetailPrimaryButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Click="RenewContractButton_Click" />
                    </StackPanel>

                    <StackPanel x:Name="OfferActionPanel" Visibility="Collapsed">
                        <TextBlock Text="Counter Amount" Style="{StaticResource DetailLabelStyle}" />
                        <TextBox x:Name="CounterFeeTextBox"
                                 Style="{StaticResource DetailTextBoxStyle}"
                                 Margin="0,0,0,8"
                                 ToolTip="Counter fee in millions" />
                        <WrapPanel>
                            <Button x:Name="AcceptOfferButton"
                                    Content="Accept"
                                    Width="90"
                                    Style="{StaticResource DetailPrimaryButtonStyle}"
                                    Margin="0,0,8,8"
                                    Click="AcceptOfferButton_Click" />
                            <Button x:Name="RejectOfferButton"
                                    Content="Reject"
                                    Width="90"
                                    Style="{StaticResource DetailDangerButtonStyle}"
                                    Margin="0,0,8,8"
                                    Click="RejectOfferButton_Click" />
                            <Button x:Name="CounterOfferButton"
                                    Content="Counter Offer"
                                    Width="124"
                                    Style="{StaticResource DetailSecondaryButtonStyle}"
                                    Margin="0,0,0,8"
                                    Click="CounterOfferButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel x:Name="CornerActionsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-4,-4,0">
                <Button x:Name="CaptainActionButton"
                        Content="C"
                        Style="{StaticResource DetailCornerActionButtonStyle}"
                        Margin="0,0,6,0"
                        Visibility="Collapsed"
                        Click="CaptainActionButton_Click" />
                <Button x:Name="LockActionButton"
                        Style="{StaticResource DetailCornerActionButtonStyle}"
                        Margin="0,0,6,0"
                        Visibility="Collapsed"
                        Click="LockActionButton_Click" />
                <Button x:Name="CornerActionButton"
                        Style="{StaticResource DetailCornerActionButtonStyle}"
                        Visibility="Collapsed"
                        Click="CornerActionButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
